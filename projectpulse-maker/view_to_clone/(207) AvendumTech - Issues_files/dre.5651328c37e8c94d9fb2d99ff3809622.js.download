ndatory:!0,key:""}],functionName:"removeElement",customValuesMap:{functionId:"612"},tooltipDefinition:"(OBJECT )",argToolTip:"(any-type )",description:"Removes and returns the specified element from a list",definition:"(<OBJECT>)",msexcel:!1,example:'list = {"red","blue","green"};<br>list.removeElement("blue");<br>info list;/// Returns: {"red","green"}'},{args:[{dataType:"LIST",name:"list2",mandatory:!0,key:""}],functionName:"removeAll",customValuesMap:{functionId:"614"},tooltipDefinition:"(LIST )",argToolTip:"(list2 )",description:"Removes all list2 elements present in list1",definition:"(<LIST>)",msexcel:!1,example:'list={"Red","Blue","Green"};<br>temp={"Green","Blue"};<br>list.removeAll(temp);<br>info list;/// Returns: {"Red"}'},{args:[{dataType:"TRUE/FALSE",name:"true/false",mandatory:!1,key:""}],functionName:"sort",customValuesMap:{functionId:"604"},tooltipDefinition:"( ? TRUE/FALSE )",argToolTip:"( ? true/false )",description:"Returns the list in the sorted order. The optional boolean specifies ascending(true)/descending(false)",definition:"()",msexcel:!1,returnType:"LIST",example:'list = {"red", "blue", "green", "yellow"};<br>info list.sort(true); /// Returns: {"blue","green","red","yellow"}'},{functionName:"size",customValuesMap:{functionId:"605"},tooltipDefinition:"()",argToolTip:"",description:"Returns a number which represents the size of the given list.",definition:"()",msexcel:!1,returnType:"NUMBER",example:'colors = {"Red", "Blue", "Green"};<br>ret = colors.size(); info ret; /// Returns: 3'},{functionName:"isEmpty",customValuesMap:{functionId:"606"},tooltipDefinition:"()",argToolTip:"",description:"Returns a Boolean value - True if the list contains no values; - false, if the list contains values",definition:"()",msexcel:!1,returnType:"TRUE/FALSE",example:'colors = {"Red", "Blue", "Green"};<br>ret = colors.isEmpty();<br>info ret; /// Returns: false'},{args:[{dataType:"NUMBER",name:"startIndex",mandatory:!0,key:""},{dataType:"NUMBER",name:"endIndex",mandatory:!1,key:""}],functionName:"subList",customValuesMap:{functionId:"607"},tooltipDefinition:"(NUMBER ,  ? NUMBER )",argToolTip:"(startIndex ,  ? endIndex )",description:"Returns a set of elements from any given list whose index is between start index, inclusive, and end index exclusive.",definition:"(<NUMBER>)",msexcel:!1,returnType:"LIST",example:'colors = {"red", "blue", "green", "yellow"};<br>list = colors.subList(1,3);<br>info list; /// Returns: {"blue","green"}'},{functionName:"distinct",customValuesMap:{functionId:"608"},tooltipDefinition:"()",argToolTip:"",description:"Returns a specified list after removing all duplicate elements from it.",definition:"()",msexcel:!1,returnType:"LIST",example:'colors = {"Red", "Green", "Green"};<br>list = colors.distinct();<br>info list;/// Returns: {"Red", "Green"}'},{args:[{dataType:"LIST",name:"list2",mandatory:!0,key:""}],functionName:"intersect",customValuesMap:{functionId:"609"},tooltipDefinition:"(LIST )",argToolTip:"(list2 )",description:"Returns a list with common elements in 2 given lists.",definition:"(<LIST>)",msexcel:!1,returnType:"LIST",example:'colors = {"red", "blue", "green", "orange"};<br>fruits = {"apple","orange","banana"};<br>list = colors.intersect(fruits);<br>info list;/// Returns: {"orange"}'},{args:[{dataType:"OBJECT",name:"any-type",mandatory:!0,key:""}],functionName:"add",customValuesMap:{functionId:"610"},tooltipDefinition:"(OBJECT )",argToolTip:"(any-type )",description:"Adds the specified element at the last of the given list",definition:"(<OBJECT>)",msexcel:!1,example:'list = {"red", "blue", "green"};<br>list.add("yellow");<br>info list;/// Returns: {"red", "blue", "green", yellow};'},{args:[{dataType:"LIST",name:"list2",mandatory:!0,key:""}],functionName:"addAll",customValuesMap:{functionId:"613"},tooltipDefinition:"(LIST )",argToolTip:"(list2 )",description:"Adds all elements to list1 from list2",definition:"(<LIST>)",msexcel:!1,example:'list = {"red"};<br>morecolors = {"green","yellow"};<b