: "Red ,Blue ,Blue"'},{args:[{dataType:"TEXT",name:"searchString",mandatory:!0,key:"text"},{dataType:"TEXT",name:"replaceString / regexPattern",mandatory:!0,key:"pattern"},{dataType:"TRUE/FALSE",name:"escapeRegexPattern",mandatory:!1,key:"option"}],functionName:"replaceFirstIgnoreCase",customValuesMap:{functionId:"157"},tooltipDefinition:"(TEXT text, TEXT pattern,  ? TRUE/FALSE option)",argToolTip:"(searchString , replaceString / regexPattern ,  ? escapeRegexPattern )",description:"Replaces the first Occurence of the string that matches the given searchString expression with the given replacementString with case insensitive",definition:"(<text>, <pattern>)",msexcel:!0,returnType:"TEXT",example:'info "Red ,Green ,Green".replaceFirstIgnoreCase("green","Blue"); /// Returns: "Red ,Blue ,Green"'},{functionName:"isAscii",customValuesMap:{functionId:"159"},tooltipDefinition:"()",argToolTip:"",description:"Returns 'True' if the given string contains only ascii values else it returns 'false'",definition:"()",msexcel:!0,returnType:"TEXT",example:'info "Zoho ".isAscii();/// Returns: true'},{args:[{dataType:"NUMBER",name:"occurence",mandatory:!0,key:""}],functionName:"repeat",customValuesMap:{functionId:"160"},tooltipDefinition:"(NUMBER )",argToolTip:"(occurence )",description:"Repeats the given string 'n' number of times",definition:"(<NUMBER>)",msexcel:!0,returnType:"TEXT",example:'info "Zoho ".repeat(5);/// Returns: "Zoho Zoho Zoho Zoho Zoho "'},{functionName:"reverse",customValuesMap:{functionId:"156"},tooltipDefinition:"()",argToolTip:"",description:"Reverse the given string",definition:"()",msexcel:!0,returnType:"OBJECT",example:'info "Zoho ".reverse();/// Returns: " ohoZ"'},{functionName:"frac",customValuesMap:{functionId:"333"},tooltipDefinition:"()",argToolTip:"",description:"Returns the fractional part of the given decimal number",definition:"()",msexcel:!0,returnType:"DECIMAL",example:"info 43217.5678.frac(); /// Returns: 0.5678"},{functionName:"toLowerCase",customVa