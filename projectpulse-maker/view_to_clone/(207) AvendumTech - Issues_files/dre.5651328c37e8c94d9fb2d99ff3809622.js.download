ory:!0,key:""}],functionName:"delete",customValuesMap:{functionId:"504"},tooltipDefinition:"(ARRAY )",argToolTip:"(value to be updated )",description:"Removes a mentioned value and the key from the Collection variable",definition:"(<ARRAY>)",msexcel:!0,example:'Items = Collection("Milk","Cream","Butter","Cheese");<br>Items.delete("Cream");<br>info Items; /// Returns: \'Milk, Butter, Cheese\''},{args:[{dataType:"ARRAY",name:"value to be updated",mandatory:!0,key:""}],functionName:"deleteAll",customValuesMap:{functionId:"505"},tooltipDefinition:"(ARRAY )",argToolTip:"(value to be updated )",description:"Removes multiple values and their keys from a Collection variable",definition:"(<ARRAY>)",msexcel:!0,example:'Items = Collection("Milk","Cream","Butter","Cheese");<br>Items.deleteAll("Cream","Cheese");<br>info Items; /// Returns: \'Milk, Butter\''},{args:[{dataType:"OBJECT",name:"value to be updated",mandatory:!0,key:""}],functionName:"deleteKey",customValuesMap:{functionId:"506"},tooltipDefinition:"(OBJECT )",argToolTip:"(value to be updated )",description:"Removes a mentioned key and the value from the Collection variable",definition:"(<OBJECT>)",msexcel:!0,example:'details = Collection("Name":"John","Age":23,"company":"Zoho");<br>details.deleteKey("Name");<br>info details; /// Returns: \'{"Age":23,"company":"Zoho"}\''},{args:[{dataType:"ARRAY",name:"value to be updated",mandatory:!0,key:""}],functionName:"deleteKeys",customValuesMap:{functionId:"507"},tooltipDefinition:"(ARRAY )",argToolTip:"(value to be updated )",description:"Removes multiple keys and their values from a Collection variable",definition:"(<ARRAY>)",msexcel:!0,example:'details = Collection("Name":"John","Age":23,"company":"Zoho");<br>details.deleteKeys({"Name","Age"});<br>info details; /// Returns: \'{"company":"Zoho"}\''},{args:[{dataType:"TRUE/FALSE",name:"value to be updated",mandatory:!1,key:""}],functionName:"sort",customValuesMap:{functionId:"508"},tooltipDefinition:"( ? TRUE/FALSE )",argToolTip:"( ? value to be updated )",description:"Updates the value in collection",definition:"()",msexcel:!0,example:'details = Collection("Name":"John","company":"Zoho");<br>details.sort(false);<br>info details;/// Returns: \'{"company":"Zoho","Name":"John"}\''},{args:[{dataType:"TRUE/FALSE",name:"value to be updated",mandatory:!1,key:""}],functionName:"sortKey",customValuesMap:{functionId:"509"},tooltipDefinition:"( ? TRUE/FALSE )",argToolTip:"( ? value to be updated )",description:"Updates the value in collection",definition:"()",msexcel:!0,example:'details = Collection("Name":"John","Age":23,"Company":"Zoho");<br>info details.sortKey(false); /// Returns: \'{"Name":"John","Company":"Zoho","Age":23}\''},{functionName:"clear",customValuesMap:{functionId:"510"},tooltipDefinition:"()",argToolTip:"",description:"Removes all values in collection",definition:"()",msexcel:!0,example:'details = Collection("Name":"John","Age":23,"company":"Zoho");<br>details.clear();<br>info details; /// Returns: \'{}\''},{args:[{dataType:"OBJECT",name:"value to be updated",mandatory:!0,key:""}],functionName:"containsKey",customValuesMap:{functionId:"511"},tooltipDefinition:"(OBJECT )",argToolTip:"(value to be updated )",description:"Checks for a specific key in collection",definition:"(<OBJECT>)",msexcel:!0,returnType:"TRUE/FALSE",example:'details = Collection("Name":"John","Age":23,"company":"Zoho");<br>info details.containsKey("Age");/// Returns: \'true\''},{args:[{dataType:"OBJECT",name:"value to be updated",mandatory:!0,key:""}],functionName:"containsValue",customValuesMap:{functionId:"512"},tooltipDefinition:"(OBJECT )",argToolTip:"(value to be updated )",description:"Checks for a specific value in collection",definition:"(<OBJECT>)",msexcel:!0,returnType:"TRUE/FALSE",example:'details = Collection("Name":"John","Age":23,"company":"Zoho");<br>info details.containsValue("John"); /// Returns: \'true\''},{args:[{dataType:"OBJECT",name:"value to be updated",mandatory:!0,key:""}],functionName:"getKey",customValuesMap:{functionId:"513"},tooltipDefinition:"(OBJECT )",argToolTip:"(value to be updated )",description:"Gets key associated to specific value in collection",definition:"(<OBJECT>)",msexcel:!0,returnType:"OBJECT",example:'details = Collection("Name":"John","Age":23,"company":"Zoho");<br>info details.getKey("John"); /// Returns: \'Name\''},{args:[{dataType:"OBJECT",name:"value to be updated",mandatory:!0,key:""}],functionName:"getLastKey",customValuesMap:{functionId:"514"},tooltipDefinition:"(OBJECT )",argToolTip:"(value to be updated )",description:"Gets the key associated to a specific value occurred at last in collection",definition:"(<OBJECT>)",msexcel:!0,returnType:"OBJECT",example:'details = Collection("Name":"John","Age":23,"company":"Zoho","product":"Zoho");<br>info details.getLastKey("Zoho");/// Returns: \'product\''},{functionName:"isEmpty",customValuesMap:{functionId:"515"},tooltipDefinition:"()",argToolTip:"",description:"Check whether the Collection variable is empty or not",definition:"()",msexcel:!0,returnType:"TRUE/FALSE",example:'details = Collection("Name":"John","Age":23,"company":"Zoho");<br>info details.isEmpty(); /// Returns: \'false\''},{functionName:"size",customValuesMap:{functionId:"516"},tooltipDefinition:"()",argToolTip:"",description:"Returns the number of values present in the variable",definition:"()",msexcel:!0,returnType:"NUMBER",example:'details = Collection("Name":"John","Age":23,"company":"Zoho");<br>info details.size(); /// Returns: \'3\''},{functionName:"keys",customValuesMap:{functionId:"517"},tooltipDefinition:"()",argToolTip:"",description:"Returns a list of all the keys present in the variable",definition:"()",msexcel:!0,returnType:"LIST",example:'details = Collection("Name":"John","Age":23,"company":"Zoho");<br>info details.keys(); /// Returns: \'Name,Age,company\''},{functionName:"values",customValuesMap:{functionId:"518"},tooltipDefinition:"()",argToolTip:"",description:"Returns a list of all the values present in the variable",definition:"()",msexcel:!0,returnType:"LIST",example:'details = Collection("Name":"John","Age":23,"company":"Zoho");<br>info details.values(); /// Returns: \'John , 23 , Zoho\''},{functionName:"distinct",customValuesMap:{functionId:"519"},tooltipDefinition:"()",argToolTip:"",description:"Returns a list of all distinct values present in Collection variable",definition:"()",msexcel:!0,returnType:"LIST",example:'Items = Collection("Milk","Butter","Cream","Cheese","Milk");<br>info Items.distinct(); /// Returns: \'Milk, Butter, Cream, Cheese\''},{args:[{dataType:"COLLECTION",name:"collection",mandatory:!0,key:""}],functionName:"intersect",customValuesMap:{functionId:"520"},tooltipDefinition:"(COLLECTION )",argToolTip:"(collection )",description:"Returns a list of common elements present in two Collection variables",definition:"(<COLLECTION>)",msexcel:!0,returnType:"LIST",example:'Items_1 = Collection("Milk","Butter","Cream","Cheese");<br>Items_2 = Collection("Milk","Butter","Cheese");<br>info Items_1.intersect(Items_2); /// Returns: \'Butter, Cheese, Milk\''},{args:[{dataType:"OBJECT",name:"startindex",mandatory:!1,key:""},{dataType:"OBJECT",name:"endIndex",mandatory:!1,key:""}],functionName:"duplicate",customValuesMap:{functionId:"521"},tooltipDefinition:"( ? OBJECT ,  ? OBJECT )",argToolTip:"( ? startindex ,  ? endIndex )",description:"Returns a set of elements from any given Collection whose index is between start index, inclusive, and end index exclusive.",definition:"()",msexcel:!0,returnType:"OBJECT",example:'Items = Collection("Milk","Butter","Cream","Cheese");<br>info Items.duplicate(1,3); /// Returns: \'Butter, Cream\''}],appliedType:["collection"]},{functions:[{args:[{dataType:"OBJECT",name:"any-type",mandatory:!0,key:""}],functionName:"contains",customValuesMap:{functionId:"617"},tooltipDefinition:"(OBJECT )",argToolTip:"(any-type )",description:"Returns 'true' if the element is present in the list",definition:"(<OBJECT>)",msexcel:!1,ret