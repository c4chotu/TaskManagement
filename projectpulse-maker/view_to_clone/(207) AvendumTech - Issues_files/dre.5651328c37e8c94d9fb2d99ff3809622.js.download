eturns: "Pad"'},{args:[{dataType:"TEXT",name:"string",mandatory:!1,key:""}],functionName:"toCollection",customValuesMap:{functionId:"125"},tooltipDefinition:"( ? TEXT )",argToolTip:"( ? string )",description:"Returns the Map from given JSON formatted String",definition:"()",msexcel:!1,returnType:"OBJECT",example:'info "read write speak".toCollection(" "); /// Returns: {"read","write","speak"}'},{args:[{dataType:"NUMBER",name:"number-of-spaces",mandatory:!0,key:""}],functionName:"right",customValuesMap:{functionId:"137"},tooltipDefinition:"(NUMBER )",argToolTip:"(number-of-spaces )",description:"Returns the specified number of characters from the right of the source text",definition:"(<NUMBER>)",msexcel:!0,returnType:"TEXT",example:'info "Pad me".right(3); /// Returns: " me"'},{functionName:"proper",customValuesMap:{functionId:"138"},tooltipDefinition:"()",argToolTip:"",description:"Capitalizes the first letter after every space, in a specified string, leaving all other letters in lowercase",definition:"()",msexcel:!0,returnType:"TEXT",example:'info "Create online database applications".proper(); /// Returns: "Create Online Database Applications"'},{args:[{dataType:"TEXT",name:"string2",mandatory:!0,key:""}],functionName:"containsIgnoreCase",customValuesMap:{functionId:"141"},tooltipDefinition:"(TEXT )",argToolTip:"(string2 )",description:"Returns 'True' if specified first string contains specified second string irrespective of uppercase/lowercase, else returns 'false'.",definition:"(<TEXT>)",msexcel:!0,returnType:"TRUE/FALSE",example:'info "RED,GREEN,BLUE".containsIgnoreCase("Blue"); /// Returns: true'},{args:[{dataType:"TEXT",name:"string2",mandatory:!0,key:""}],functionName:"notContains",customValuesMap:{functionId:"142"},tooltipDefinition:"(TEXT )",argToolTip:"(string2 )",description:"Returns 'True' if specified first string does not contain specified second string, else returns 'false', while the search performed is strictly case-sensitive.",definition:"(<TEXT>)