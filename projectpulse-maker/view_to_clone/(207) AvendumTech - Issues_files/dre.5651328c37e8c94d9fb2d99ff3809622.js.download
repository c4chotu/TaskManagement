21"},tooltipDefinition:"()",argToolTip:"",description:"Returns the angle of the inverse hyperbolic tangent ( in radians)",definition:"()",msexcel:!0,returnType:"DECIMAL",example:"info 0.5.atanh(); /// Returns: 0.549306144334"},{functionName:"acosh",customValuesMap:{functionId:"322"},tooltipDefinition:"()",argToolTip:"",description:"Returns the angle of the inverse hyperbolic cosine ( in radians)",definition:"()",msexcel:!0,returnType:"DECIMAL",example:"info 2.acosh(); /// Returns: 1.316957896925"},{functionName:"asinh",customValuesMap:{functionId:"323"},tooltipDefinition:"()",argToolTip:"",description:"Returns the angle of the inverse hyperbolic sine ( in radians)",definition:"()",msexcel:!0,returnType:"DECIMAL",example:"info 1.asinh(); /// Returns: 0.88137358702"},{functionName:"cosh",customValuesMap:{functionId:"325"},tooltipDefinition:"()",argToolTip:"",description:"Returns the angle of the hyperbolic cosine ( in radians)",definition:"()",msexcel:!0,returnType:"DECIMAL",example:"info 0.cosh(); /// Returns: 1.0"},{functionName:"sinh",customValuesMap:{functionId:"326"},tooltipDefinition:"()",argToolTip:"",description:"Returns the angle of the hyperbolic sine ( in radians)",definition:"()",msexcel:!0,returnType:"DECIMAL",example:"info 1.sinh(); /// Returns: 1.175201193644"},{functionName:"tanh",customValuesMap:{functionId:"324"},tooltipDefinition:"()",argToolTip:"",description:"Returns the angle of the hyperbolicc tangent ( in radians)",definition:"()",msexcel:!0,returnType:"DECIMAL",example:"info 1.tanh(); /// Returns: 0.761594155956"},{args:[{dataType:"DECIMAL",name:"angle2",mandatory:!0,key:""}],functionName:"atan2",customValuesMap:{functionId:"327"},tooltipDefinition:"(DECIMAL )",argToolTip:"(angle2 )",description:"Returns the angle in the plane (in radians) between the positive x-axis and the ray from (0,0) to the point (x,y)( in radians)",definition:"(<DECIMAL>)",msexcel:!0,returnType:"DECIMAL",example:"info 1.atan2(2); /// Returns: 0.463647609001"},{functionN