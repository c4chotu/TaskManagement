	// Determine whether zd-library files should be loaded (Skip if its inside an iframe)
	var isNotInIframe = window.self === window.top;


	// --- Set window.ZUnify.serviceData (before static-loader loads any scripts) ---
	window.ZUnify = window.ZUnify || {}; // No I18N
	// No-I18N comment code check error is coming when we use it without `out.println` tag
	var oeServiceData = {"isOneBarEnabled":false,"zaaid":"60032529757","isOEEnabled":false,"appName":"projects","isBundleCase":false,"isNavBarEnabled":false,"isZOBundle":false,"context":"","isOneExperienceEnabled":false,"isBundlePresent":false,"zuid":"60044831901","isLauncherSupported":false};

	oeServiceData.willOneBarLibraryLoad = oeServiceData.isOneBarEnabled && isNotInIframe; // No I18N
	window.ZUnify.serviceData = oeServiceData; // No I18N

	// Add one_experience class to body early to prevent layout shift (left: 40px space)
	if (oeServiceData.isOneBarEnabled && oeServiceData.isBundleCase && oeServiceData.isZOBundle && document.body) { // No I18N
		document.body.classList.add('one_experience'); // No I18N
	}

	











var docHead = document.head || document.getElementsByTagName("head" )[0] || document.documentElement;

function zdLibraryOnLoadHandler() {

	// --- Inject ZUnify.js (always, irrespective of old or new flow) ---
	
		if (!(window.ZUnify && window.ZUnify.isZUnifyLibLoaded)) { // No I18N
			var zunifyScript = document.createElement("script"); // No I18N
			zunifyScript.src = "https:\/\/static.zohocdn.com\/zunify\/zunify.min.js"; // No I18N
			zunifyScript.type = "text/javascript"; // No I18N
			docHead.appendChild(zunifyScript); // No I18N
		}
	

	
};


function includeScript(urlObj, callback) { // No I18N
	var script = document.createElement("script"); // No I18N
	script.src = urlObj.url; // No I18N
	script.crossOrigin = "anonymous"; // No I18N
	var integrityHash = urlObj.hash; // No I18N
	if (integrityHash && integrityHash.trim() !== "") { // No I18N
		script.integrity = integrityHash; // No I18N
	}
	if (callback) { // No I18N
		script.onload = script.onreadystatechange = function() {
			if (!this.readyState || this.readyState === "loaded" || this.readyState === "complete") {
				callback(); // No I18N
				script.onload = script.onreadystatechange = null; // To avoid calling repeatedly in IE // No I18N
			}
		};
	}
	docHead.appendChild(script); // No I18N
};

if(document.readyState == "complete") { // Call the handler if DOM already loaded.
	zdLibraryOnLoadHandler(); 
} else { 
	// Should not use `window.onload` as it might be overridden by service team
	if (window.addEventListener) {
	  window.addEventListener('load', zdLibraryOnLoadHandler, false); 
	} else if (window.attachEvent)  { 
	  window.attachEvent('onload', zdLibraryOnLoadHandler); 
	}
}

