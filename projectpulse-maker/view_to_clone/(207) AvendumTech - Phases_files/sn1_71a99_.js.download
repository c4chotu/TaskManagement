window.exportcustomfield='<div class="zps-form-field full-field"> <div class="field-label-holder"> <label data-tooltip="${getI18nValue(\'zp.tasks.exportselectedcolumn\')}" ellipsis="true">${getI18nValue(\'zp.tasks.exportselectedcolumn\')}</label> </div> <div id="leftAvailableField" class="export-column-select" export-of="{{if MODULE==\'TASK\' }}task{{else}}timesheet{{/if}}" word-wrap="true">  <div class="export-column-section">  <div class="field-label-holder">  <span class="form-group-label">${getI18nValue(\'zp.tasks.withattachment\')}</span>  </div>  <div id="unusedcolumns" class="export-column-container">  <div class="export-column-header">  <div class="zps-pop-searchbar">  <i class="zoho-search" onclick="$L(\'#searchField1\').focus();"></i>  <input id="searchField1" data-zcqa="dash_searchField_chooseColumns" type="text" autocomplete="off" onkeyup="taskExportsearch(this);" placeholder="${getI18nValue(\'zp.submit.search\')}">  <i id="emptyselectedSearch" class="zoho-clear" style="display:none;" onclick="Utils.emptySearchBox();$L(\'#searchField\').focus();"></i>  </div>  <div id="moveall_unused" columntype="left" class="move-all" onclick="bulkleftSelectAllTrigger(event,\'left\')" tabindex="0">   <span id="moveall_left" ellipsis="true" data-tooltip="${getI18nValue(\'zp.tasks.selectedmoveall\')}" onclick="selectAlltaskExportView()"><span>${getI18nValue(\'zp.tasks.selectedmoveall\')}</span><i class="zoho-kybd-arwR pl5"></i></span>  </div>  </div>  <div id="leftColumns" class="left-box-data ui-sortable widget-custom-scroll" columnside="left">  {{if DEFAULTCUSTOMFIELDS && DEFAULTCUSTOMFIELDS.length>=1}}  {{each(i,CUSTOMDETAIL) DEFAULTCUSTOMFIELDS}}  {{if CUSTOMDETAIL.PCFID !="60" }}  <div class="export-column-list optsel" id="${CUSTOMDETAIL.PCFID}" columnid="${CUSTOMDETAIL.PCFID}" columntype="left">  {{if CUSTOMDETAIL.PCFID =="30"}}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'zp.attach.description\')}" customfield="${CUSTOMDETAIL.PCFID}">${getI18nValue(\'zp.attach.description\')}</div>  {{else}}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${CUSTOMDETAIL.ALIASNAME}" customfield="${CUSTOMDETAIL.PCFID}">${CUSTOMDETAIL.ALIASNAME}</div>  {{/if}}  <i id="news" class="move-right-action zoho-right-arrow-plain" onclick="taskExportDragableColumns(this); "></i></div>  {{/if}}  {{/each}}  {{/if}}    {{if ALLCUSTOMFIELDS && ALLCUSTOMFIELDS.length>=1}}  {{each(i,CUSTOMDETAIL) ALLCUSTOMFIELDS}}  {{if CUSTOMDETAIL.ISPLANSUPPORTED == true}}  {{if CUSTOMDETAIL.ISVISIBLE == 0 && ( CUSTOMDETAIL.COLUMNNAME !="TODOLISTTITLE" && CUSTOMDETAIL.COLUMNNAME!="MILESTONETITLE" && CUSTOMDETAIL.COLUMNNAME!="TIMELOG" && CUSTOMDETAIL.COLUMNNAME!="DIFFERENCE") && CUSTOMDETAIL.COLUMNNAME!="ISRECURRINGSET" && CUSTOMDETAIL.COLUMNNAME!="ISREMINDERSET" }}  <div class="export-column-list optsel" id="${CUSTOMDETAIL.PCFID}" columnid="${CUSTOMDETAIL.PCFID}" columntype="left">  {{if CUSTOMDETAIL.COLUMNNAME =="TODODUEDATE"}}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'zp.task.st\')}" customfield="${CUSTOMDETAIL.PCFID}">${getI18nValue(\'zp.task.st\')}</div>  {{else CUSTOMDETAIL.COLUMNNAME =="TODOENDDATE"}}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'DueDate\')}" customfield="${CUSTOMDETAIL.PCFID}">${getI18nValue(\'DueDate\')}</div>  {{else CUSTOMDETAIL.COLUMNNAME =="PERCENTCOMPLETE"}}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'zp.reports.percomp\')}" customfield="${CUSTOMDETAIL.PCFID}">${getI18nValue(\'zp.reports.percomp\')}</div>  {{else CUSTOMDETAIL.COLUMNNAME == "CUSTOM_STATUSID" }}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'zp.reports.status\')}" customfield="${CUSTOMDETAIL.PCFID}">${getI18nValue(\'zp.reports.status\')}</div>  {{else CUSTOMDETAIL.COLUMNNAME == "DURATION" }}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'zp.task.duration\')}" customfield="${CUSTOMDETAIL.PCFID}">${getI18nValue(\'zp.task.duration\')}</div>  {{else CUSTOMDETAIL.COLUMNNAME == "PRIORITY" }}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'zp.reports.priority\')}" customfield="${CUSTOMDETAIL.PCFID}">${getI18nValue(\'zp.reports.priority\')}</div>  {{else CUSTOMDETAIL.COLUMNNAME == "TODOCOMPLETEDON" }}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'zp.workflow.completiondate\')}" customfield="${CUSTOMDETAIL.PCFID}">${getI18nValue(\'zp.workflow.completiondate\')}</div>   {{else CUSTOMDETAIL.COLUMNNAME == "CREATEDTIME" }}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'CreatedOn\')}" customfield="${CUSTOMDETAIL.PCFID}">${getI18nValue(\'CreatedOn\')}</div>  {{else CUSTOMDETAIL.COLUMNNAME == "WORK" }}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'zp.planhrs.workhrs\')}" customfield="${CUSTOMDETAIL.PCFID}">${getI18nValue(\'zp.planhrs.workhrs\')}</div>  {{else CUSTOMDETAIL.COLUMNNAME == "BILLABLELOGHRS" }}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'zp.pagetour.headercontent66\')} ( ${getI18nValue(\'zp.timesheet.billable\')} )" customfield="${CUSTOMDETAIL.PCFID}">${getI18nValue(\'zp.pagetour.headercontent66\')} ( ${getI18nValue(\'zp.timesheet.billable\')} )</div>  {{else CUSTOMDETAIL.COLUMNNAME == "RATE_PER_HOUR" }}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'zp.invoice.rateperhour\')}" cust