v class="mlt-item-group">${TLOBJ.forecasted_hours_formatted}</div>  </td>  {{/if}} {{/if}}  {{if ISBUDGETENABLED=="true" && (ProjectBudget.isBudgetByAmount(BUDGET_TYPE) || BUDGET_TYPE=="0")}} {{if permissions.task.permission.view_all && !IS_WORKFIELD_REMOVED}}  <td class="zps-cell-td " id="pcost_${TLOBJ.TLID}">  <div class="mlt-item-group">${TLOBJ.planned_cost_formatted}</div>  </td>  {{/if}}  {{if PSTAT!="template" && permissions.timesheet.permission.view_all}}  <td class="zps-cell-td " id="acost_${TLOBJ.TLID}">  <div class="mlt-item-group">${TLOBJ.actual_cost_formatted}</div>  </td>  {{/if}} {{if PSTAT!="template" && permissions.task.permission.view_all && permissions.timesheet.permission.view_all && !IS_WORKFIELD_REMOVED}}  <td class="zps-cell-td " id="bcost_${TLOBJ.TLID}">  <div class="mlt-item-group{{if TLOBJ.BALANCE_COST<0}} colf0536d {{else TLOBJ.BALANCE_COST>0}} col37ad42 {{/if}}">${TLOBJ.balance_cost_formatted}</div>  </td>  <td class="zps-cell-td " id="fcost_${TLOBJ.TLID}">  <div class="mlt-item-group">${TLOBJ.forecasted_cost_formatted}</div>  </td>  {{/if}} {{/if}} {{if Utils.isTaggingAvailable}} <td class="zps-cell-td "> <div class="mlt-app-itemcontainer"> {{html Tags.controller.renderTags({ projectId : projectId, entityType : Tags.Constants.EntityType.TASKLIST, entityId : TLOBJ.TLID, associatedTags : TLOBJ.TAGS, view : Tags.Constants.pageView.list, isEditable : permissions.tasklist.permission.edit })}} </div> </td> {{/if}}  <td class="zps-cell-td ">  MILETLTASKCNTPLACEHOLDER  </td>  <td class="zps-cell-td "></td>  </tr>  {{/each}}  {{/if}}   {{else SHOWPFOR == "MILECOMMENT"}}  {{if NOTES}}  {{each(i,NOTEOBJ) NOTES}}  <div id="trCommnmhover_${NOTEOBJ.COMMID}" class="zps-comment-section" data-user="${NOTEOBJ.ISPERM}" data-id="${NOTEOBJ.COMMID}" tabindex="0">  <div class="zps-commenter-pic">  <profile-img src="${NOTEOBJ.PHOTOURL}" name="${NOTEOBJ.DISPNAME}"></profile-img>  </div>  <div class="zps-comments-content">  <div class="comment-title"> <div class="commenter-name"> ${NOTEOBJ.DISPNAME} </div> </div>  <div class="comments-data">  \x3c!-- HTML purifier will remove the onclick in a tags. Our Atmention click(opening user details page) has been handled using onclick. So after purifying the atmentions replaced with a tags. --\x3e  <div id="nmcommCnt_${NOTEOBJ.COMMID}" class="content-from-user breakWord lh22">{{html replaceMentionsValueWithDiv(NOTEOBJ.VIEWCOMMENT)}}</div>  \x3c!-- Edit commeny also shold have the same content as Display. So the content process done some as view comment. --\x3e  <div id="nmeditcommCnt_${NOTEOBJ.COMMID}" style="display:none;">{{html replaceMentionsValueWithDiv(NOTEOBJ.EDITCOMMENT)}}</div>  <div id="filecont_${NOTEOBJ.COMMID}">  <div id="msothernotes_${NOTEOBJ.COMMID}" class="attach-cover">  <div class="attach-data">  <i class="zoho-ftfill-html"></i>  </div>    <div class="attach-action">  <div class="attach-fname" data-tooltip="File name" ellipsis="true">name</div>  <div class="attach-btn">    </div>  </div>    </div>  <script>  if (jQuery(".msfilenotes_${NOTEOBJ.COMMID}").length > 0) {  jQuery(".msfilenotes_${NOTEOBJ.COMMID}").appendTo("#msothernotes_${NOTEOBJ.COMMID}");  } else {  jQuery("#msothernotes_${NOTEOBJ.COMMID}").addClass("hide");  }  <\/script>  </div>  </div>  <div class="comments-particulars">  <span>${NOTEOBJ.DISPINFO}</span>  {{if NOTEOBJ.ISPERM}}  <span class="link" visibility="hover"><a class="nmeditcomm" href="javascript:;" data-setid="${NOTEOBJ.COMMID}" data-zpqa="mileqa_edit_cmnt">${getI18nValue(\'zp.general.edit\')}</a></span>  <span class="link" visibility="hover"><a class="nmdelcomm" href="javascript:;" data-zpqa="mileqa_delete_cmnt" data-setid="${NOTEOBJ.COMMID}">${getI18nValue(\'zp.general.delete\')}</a></span>  {{/if}} </div>  </div>  </div>  {{/each}}  {{/if}}  {{if NEWCOMM}}  <script>setInlineMileHgts("","comment");<\/script>  {{else}}  <script>setInlineMileHgts("firsttime","comment");<\/script>  {{/if}} {{else SHOWPFOR == "ASSOCTLIST"}}  {{if TLISTDET}}  {{each(i,TLISTOBJ) TLISTDET}}  <div class="pt13 pb13 bdrbtm4 table w98perimp">  <div class="fl w20">  <img data-tid="${TLISTOBJ.TLISTID}" class="taskchkbox pointer" >  </div>  <div valign="top" class="fl pl3 text-ellipsis w650">  <a class="vptxt" href="javascript:;" id="nmact_${TLISTOBJ.TLISTID}">${TLISTOBJ.TLISTNAME} (${TLISTOBJ.TMILETITLE})</a>  </div>  </div>  {{/each}}  <script>  jQuery("[id^=\'assmileset_\']").bind("click",function(){  jQuery(this).parent().find("img").trigger("click");   });  jQuery(".assocChkbx").bind("click",function(e){  var thisElem = jQuery(this);  if (thisElem.hasClass("taskchkbox")){  thisElem.addClass("taskchkboxTick").removeClass("taskchkbox");  var tlid = jQuery.trim(""+thisElem.data("tlid"));  jQuery("#inpasschk_"+tlid).attr("checked","checked");  }else{  thisElem.removeClass("taskchkboxTick").addClass("taskchkbox");  var tlid = thisElem.data("tlid");jQuery("#inpasschk_"+tlid).removeAttr("checked");  }  });  <\/script> {{/if}} {{/if}} ',window.newmilebugview=' <div id="milepop_left2" class="mlt_in_milestone"></div>  <div id="bug_emptynewmile" class="hide">  <div class="empty-state-container">  <img src="${getCdnUrl(\'img\',\'images/svg/emptylargeicon/empty_state_bug.svg\')}" class="empty-state-img">  <div class="emptyscreen-h1" id="nm_bg_txt_nobug">${getBugRepValue(\'zp.milestone.associatebugs\',\'plural\')}</div> {{if permissions.bug.permission.create}} <div class="emptyscreen-h4 mb20">${getI18nValueWithParam(\'zp.bug.bugmileassociate\',[Utils.bugPluralValue,Utils.milestoneSingularValue.toLowerCase()])}</div> <span class="zps-primary-button" id="emptyCreatenm_bug" data-zpqa="mileqa_bug_create">${getBugRepValue(\'zp.bug.fileabug\',\'single\')}</span> {{/if}}  </div>  </div>  <script> var projId = jQuery("#mprojId").text(); var bugPropParam = "projId="+projId+"&prop=customFields&"+getZPCSRF(); jQuery("div[bid=hangBut]").click(function(){ showHangPop(); }); jQuery("#buglist_edit_action,#emptyCreatenm_bug").bind("click",function(){ addBu