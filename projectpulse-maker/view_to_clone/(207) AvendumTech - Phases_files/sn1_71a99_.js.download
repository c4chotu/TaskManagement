eys kybds-lascent-key gdcolumn-span3"> <span>ctrl</span> </div> <div mapkey="alt" class="kybd-shrt-keys kybds-lascent-key"> <span>alt</span> </div> <div class="kybd-shrt-keys gdcolumn-span3 kybd-desl-key"></div> <div mapkey="space" class="kybd-shrt-keys kybds-lascent-key gdcolumn-span11"> <span>Space</span> </div> <div class="kybd-shrt-keys gdcolumn-span3 kybd-desl-key"></div> <div mapkey="alt" class="kybd-shrt-keys kybds-lascent-key"> <span>alt</span> </div> <div class="keyboard-arrow-section"> <div class="keyboard-arrow-cont"> <div id="keyBD_ArrowLID" class="keybrd-arrow-key" mapkey="left"> <i class="zoho-kybd-left"></i> </div> <div class="keyboard-arrow-updwnkey"> <div id="keyBD_ArrowUID" class="keybrd-arrow-key" mapkey="up"> <i class="zoho-kybd-up"></i> </div> <div id="keyBD_ArrowDID" class="keybrd-arrow-key" mapkey="down"> <i class="zoho-kybd-down"></i> </div> </div> <div id="keyBD_ArrowRID" class="keybrd-arrow-key" mapkey="right"> <i class="zoho-kybd-right"></i> </div> </div> </div> </div> </div>  </div> </div>',window.taskcntbar='<div id="tasktlcounter_${TLID}" onclick="jQuery(\'#tlistnameid_${TLID}\').trigger(\'click\');"> {{if TCLOSE == "0" && TOPEN == "0"}} <div class="mlt-app-progress-empty pointer">${getI18nValueWithModule(\'zp.calendar.notasks\', Utils.taskPluralValue)}</div> {{else}} <div class="mlt-progress-container">  <div id="mltclcnt_${TLID}" class="progress-value close-link" data-tooltip="${TCLOSE} ${getI18nValueWithModule(\'zp.reports.closedtasks\', Utils.taskPluralValue)}">${TCLOSE}</div>  <div class="posrel ml3 mr3 w80">  {{if TCLOSE != "0" || TOPEN != "0"}}  <div class="percentCount" name="percentcomplete_${TLID}"></div>  {{/if}}  <div class="mlt-app-progress">  <div id="milegreenbar_${TLID}" class="greenbar close-link" data-tooltip="${TCLOSE} ${getI18nValueWithModule(\'zp.taskreports.closed\', Utils.taskSingularValue)}" style="width: ${GREENBARW}%;"></div>  <div id="mileredbar_${TLID}" class="redbar open-link" redirect="milelink" data-tooltip="${TOPEN} ${getI18nValueWithModule(\'zp.taskreports.open\', Utils.taskSingularValue)}" style="width: ${REDBARW}%;"></div>  </div>  </div>  <div id="mltopcnt_${TLID}" class="progress-value open-link" data-tooltip="${TOPEN} ${getI18nValueWithModule(\'zp.reportsnew.opentasks\', Utils.taskPluralValue)}">${TOPEN}</div> </div>  <script>  var comp = parseInt(${GREENBARW});  if (comp != 0 && comp != 100) {  jQuery("[name=\'percentcomplete_${TLID}\']").text(comp + " %");  var tComplTxt = getI18nValueWithModule(\'zp.projpage.taskscomp\', Utils.taskPluralValue);  var tComplOf = getI18nValue(\'zp.general.of\');  var percentage = parseInt("${TCLOSE}") + parseInt("${TOPEN}");  jQuery("[name=\'percentcomplete_${TLID}\']").attr("data-tooltip", comp + "% [${TCLOSE} " + tComplOf + " " + percentage + " " + tComplTxt + "]");  } <\/script> {{/if}}  </div> ',window.invoiceinteg='<table width="100%" cellspacing="0" cellpadding="0" border="0">   <tr>  <td valign="top" class="w73per">  {{if fromPage!=\'setup\'}} <div class="rightdivtop2 mb20 backoption"> <div class="fl backoption1 hide">  <a id="invIntegbackId" title="${getI18nValue(\'zp.mapusr.back\')}" href="javascript:;" class="block chkbox h45">  <div class="zpbackoption posrel T17 L8"></div>  </a>  <script>  jQuery("#invIntegbackId").click(function() {  modifyURL(\'settings\');  ShowGenBlock(\'ajax_load_tab\');  changeMenuStyle(\'settinglink\');  ajaxJsonShowPage(Utils.contPath+\'/tabheaders.do\',getZPCSRF()+\'&projId=0\',\'0\');  });  <\/script> </div> <div class="fl pt12 tasklistTitle pl36"> <div class="fl tac pointer mr20 viewsel_bdr">${serviceDispName} Integration</div> </div> </div> {{/if}} {{tmpl invoiceintegcont}} </td></tr></table> ',window.invoicelist='{{each(i,inv) invoices}}  <tr id="inv_${inv.invoice_id}" class="taskDescRow" onmouseover="ShowGenInline(\'delInvoice_${inv.invoice_id}\');this.className=\'taskDescRowHover pointer\'" onmouseout="Hide(\'delInvoice_${inv.invoice_id}\');this.className=\'taskDescRow\'">  <td class="w30 pl3 pr3 bgwhite pt10 vat">  {{if inv.project_count && inv.project_count > 1}}  <div class="inv_projcount" onmouseover="ShowGenInline(\'multi_proj_${inv.invoice_id}\');" onmouseout="Hide(\'multi_proj_${inv.invoice_id}\')">${inv.project_count}</div> <div style="position: absolute; margin-left: 35px; margin-top: -40px;" id="multi_proj_${inv.invoice_id}" class="hide"> <div class="txtSmall zps-pop-container w250 p0imp tal default"> <div style="position: relative; top:20px; left:-12px; width:20px; height: 15px;" id="tarrowtop"><img class="zplarrow"></div> <div class="pb20 qulbl2 lh20"> <div class="h20 vptxt font-medium bdrbtm pl15 pb5">Multi-Project Invoice</div> {{each(p,proj) inv.projects}} <div class="pt10 pl15">${proj}</div> {{/each}} </div> </div> </div>  {{/if}}  </td>  <td class="bdrbtm5 pt12 pb13 ownerminmax fs14px pl5" id="invdate_${inv.invoice_id}">${inv.date_formatted}</td>  <td class="bdrbtm5 pt12 pb13 col428bca spaceNowrap fs14px" id="${inv.invoice_id}" name="invoiceId">${inv.invoice_number}</td>  <td class="bdrbtm5 pt12 pb13 spaceNowrap fs14px" id="invord_${inv.invoice_id}">${inv.reference_number}</td>  {{if module == \'invoicelist\'}}  <td class="bdrbtm5 pt12 pb13 projnameminmax1new pl10" align="left"><span class="fs14px" id="${inv.invoice_id}" name="invname">${inv.customer_name}</span></td>  {{/if}}  <td class="bdrbtm5 pl10 pt12 pb13 ownerminmax fs14px on-data-light" id="invstat_${inv.invoice_id}">${inv.status_formatted}</td>  <td class="bdrbtm5 pl10 pt12 pb13 ownerminmax fs14px" id="invdate_${inv.invoice_id}">${inv.due_date_formatted}</td>  <td class="bdrbtm5 pr15 fs14px" valign="middle" id="invtotal_${inv.invoice_id}">${inv.total_formatted}</td>  <td class="bdrbtm5 fs14px"> <div class="w20"><span id="delInvoice_${inv.invoice_id}" class="hide"><div class="zoho-trash" title="Delete" style="margin-top:-5px;"></div></span></div></td>  </tr>  <script>  jQuery("#delInvoice_${inv.invoice_id}").click(function(e) {  stopEvents(e);  if(askOnDelete(getI18nValue(\'zp.functionjs.delinvoicewarn\'))) {  deleteInvoice(\'${inv.invoice_id}\');  }  });    var invStatus = \'${inv.status}\';  if(invStatus) {  if(invStatus.indexOf(\'sent\') != -1) {  jQuery(\'#invstat_${inv.invoice_id}\').addClass(\'ribbon-open\');  } else if(invStatus.indexOf(\'paid\') != -1) {  jQuery(\'#invstat_${inv.invoice_id}\').addClass(\'ribbon-success\');  } else if(invStatus.indexOf(\'overdue\') != -1) {  jQuery(\'#invstat_${inv.invoice_id}\').addClass(\'ribbon-overdue\');  } else if(invStatus.indexOf(\'draft\') != -1) {  jQuery(\'#invstat_${inv.invoice_id}\').addClass(\'ribbon-draft\');  } else if(invStatus.indexOf(\'void\') != -1) {  jQuery(\'#invstat_${inv.invoice_id}\').addClass(\'ribbon-void\');  }  }    <\/script>  {{/each}}  <script>  {{if module == "clientinvoice"}} var morecust = jQuery("#morebtn_${customer_id}"); {{if has_more_invoices}} morecust.unbind("click"); morecust.click(function(){ fetchInvoiceData(\'invoicelist.do\', \'projId=${PROJID}&pageNumber=${page_context.page + 1}&clientCompId=${customer_id}\',\'customerInvoice_${customer_id}\',\'invoicelist\',\'${PROJID}\'); }); {{else}} jQuery("#more_${customer_id}").remove(); {{/if}} {{else module == "invoicelist"}} getMoreOnScroll(function(){ {{if page_context.has_more_page}} Show(\'floaddiv\'); fetchInvoiceData(\'invoicelist.do\', \'projId=${PROJID}&pageNumber=${page_context.page + 1}\',\'invoicelistbody\',\'invoicelist\',\'${PROJID}\'); {{/if}} },"invoicelistbody",\'vertical\'); {{/if}}  <\/script> ',window.miledisplayproj='{{if PROJARRAY}}  {{if SINDEX==1}}  <thead name="projheader" id="projhead_${PROJID}" typ="contdiv" class="table-header">  <tr class="mslinehdr">  <th field-type="appname">  <div class="flex posrel">  <span class="mlt-single-action"></span>  <span class="mlt-header-name">${getI18nValue(\'zp.milestones.milestone\')}</span>  </div>  </th>  <th field-type="percentage"><span class="mlt-header-name">%</span></th>  <th field-type="ownername"><span class="mlt-header-name">${get