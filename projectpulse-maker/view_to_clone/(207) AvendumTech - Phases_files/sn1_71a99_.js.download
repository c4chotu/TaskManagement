sage:getI18nValue(\'zp.timesheet.noexpdata\')});  return;  }  UI.Utils.loadForm(jQuery.tmpl(\'rlenotesexporttable\',expData));  UI.Utils.freezeScreen(true); }); });  jQuery("#expandcollapse_upcoming").bind("click",function(){  var expandEle = event.currentTarget; var icon = expandEle.firstElementChild;  var isExpand = expandEle.getAttribute("data-isexpand");  if(isExpand == \'true\'){  jQuery("#ul_mile_upcoming,#ul_reorder_upcoming,#ul_mile_upcoming_header").addClass("hide");  jQuery("#ul_reorder_upcoming").attr("data-visibility","false");  if(!jQuery("#ul_more_upcoming").hasClass("hide")){   jQuery("#ul_more_upcoming").addClass("hide");  upcomingMoreCollapse = true;  }else{  upcomingMoreCollapse = false;  }  icon.classList.remove(\'zoho-top-arrow-plain\');  icon.classList.add(\'zoho-down-arrow-plain\');  icon.setAttribute(\'data-tooltip\', getI18nValue(\'zp.temptodo.expandlist\'));  expandEle.setAttribute(\'data-isexpand\', \'false\');  }else{  jQuery("#ul_mile_upcoming,#ul_reorder_upcoming,#ul_mile_upcoming_header").removeClass("hide");  if(upcomingMoreCollapse){  jQuery("#ul_more_upcoming").removeClass("hide");  }  icon.classList.remove(\'zoho-down-arrow-plain\');  icon.classList.add(\'zoho-top-arrow-plain\');  icon.setAttribute(\'data-tooltip\', getI18nValue(\'zp.temptodo.collapselist\'));  expandEle.setAttribute(\'data-isexpand\', \'true\');  }  });  jQuery("[id^=\'upcomingmilesort_\'],[id^=\'msubSortIcon_upcoming_\']").bind("click",function(){ var sortEle = jQuery(this); var type = sortEle.attr("id").split("_")[1];  if(sortEle.attr(\'id\').startsWith(\'msubSortIcon_upcoming_\')){  type = sortEle.attr(\'id\').split(\'msubSortIcon_upcoming_\')[1];  sortEle = jQuery(\'#upcomingmilesort_\'+type);  }  milestoneSort("upcoming",type,sortEle);  });    jQuery("#expandcollapse_completed").bind("click",function(){  var expandEle = event.currentTarget; var icon = expandEle.firstElementChild;  var isExpand = expandEle.getAttribute("data-isexpand");  if(isExpand == \'true\'){  jQuery("#ul_mile_completed,#ul_mile_completed_header").addClass("hide");  if(!jQuery("#ul_more_completed").hasClass(\'hide\')){   jQuery("#ul_more_completed").addClass(\'hide\');  completedMoreCollapse = true;  }else{  completedMoreCollapse = false;  }  icon.classList.remove(\'zoho-top-arrow-plain\');  icon.classList.add(\'zoho-down-arrow-plain\');  icon.setAttribute(\'data-tooltip\', getI18nValue(\'zp.temptodo.expandlist\'));  expandEle.setAttribute(\'data-isexpand\', \'false\');  }else{  var completedFetchStatus = jQuery("#completed_fetch_status").val();  if(completedFetchStatus=="true"){  var durl = jQuery("#completed_fetch_durl").val();  var ddata = jQuery("#completed_fetch_ddata").val();  jQuery("#completed_fetch_status").attr("value","false");  jQuery("#completed_fetch_durl").attr("value","");  jQuery("#completed_fetch_ddata").attr("value","");  loadMyMileMoreView("true","1",durl,ddata+"&mstype=completed","ul_more_completed","completed");  }  jQuery("#ul_mile_completed,#ul_mile_completed_header").removeClass("hide");  if(completedMoreCollapse){  jQuery("#ul_more_completed").removeClass(\'hide\');  }  icon.classList.remove(\'zoho-down-arrow-plain\');  icon.classList.add(\'zoho-top-arrow-plain\');  icon.setAttribute(\'data-tooltip\', getI18nValue(\'zp.temptodo.collapselist\'));  expandEle.setAttribute(\'data-isexpand\', \'true\');  }  });  jQuery("[id^=\'completedmilesort_\'],[id^=\'msubSortIcon_completed_\']").bind("click",function(){ var sortEle = jQuery(this); var type = sortEle.attr("id").split("_")[1];  if(sortEle.attr(\'id\').startsWith(\'msubSortIcon_completed_\')){  type = sortEle.attr(\'id\').split(\'msubSortIcon_completed_\')[1];  sortEle = jQuery(\'#completedmilesort_\'+type);  }  milestoneSort("completed",type,sortEle);  });  jQuery("#expandcollapse_archived").bind("click",function(){  var expandEle = event.currentTarget; var icon = expandEle.firstElementChild;  var isExpand = expandEle.getAttribute("data-isexpand");  if(isExpand == \'true\'){  jQuery("#ul_mile_archived,#ul_mile_archived_header").addClass("hide");  if(!jQuery("#ul_more_archived").hasClass(\'hide\')){   jQuery("#ul_more_archived").addClass(\'hide\');  archivedMoreCollapse = true;  }else{  archivedMoreCollapse = false;  }  icon.classList.remove(\'zoho-top-arrow-plain\');  icon.classList.add(\'zoho-down-arrow-plain\');  icon.setAttribute(\'data-tooltip\', getI18nValue(\'zp.temptodo.expandlist\'));  expandEle.setAttribute(\'data-isexpand\', \'false\');  }else{  var archivedFetchStatus = jQuery("#archived_fetch_status").val();  if(archivedFetchStatus=="true"){  var durl = jQuery("#archived_fetch_durl").val();  var ddata = jQuery("#archived_fetch_ddata").val();  jQuery("#archived_fetch_status").attr("value","false");  jQuery("#archived_fetch_durl").attr("value","");  jQuery("#archived_fetch_ddata").attr("value","");  loadMyMileMoreView("true","1",durl,ddata+"&mstype=archived","ul_more_archived","archived");   }  jQuery("#ul_mile_archived,#ul_mile_archived_header").removeClass("hide");  jQuery(this).addClass("hide");  if(archivedMoreCollapse){  jQuery("#ul_more_archived").removeClass(\'hide\');  }  icon.classList.remove(\'zoho-down-arrow-plain\');  icon.classList.add(\'zoho-top-arrow-plain\');  icon.setAttribute(\'data-tooltip\', getI18nValue(\'zp.temptodo.collapselist\'));  expandEle.setAttribute(\'data-isexpand\', \'true\');  }  });  jQuery("[id^=\'archivedmilesort_\'],[id^=\'msubSortIcon_archived_\']").bind("click",function(){ var sortEle = jQuery(this); var type = sortEle.attr("id").split("_")[1];  if(sortEle.attr(\'id\').startsWith(\'msubSortIcon_archived_\')){  type = sortEle.attr(\'id\').split(\'msubSortIcon_archived_\')[1];  sortEle = jQuery(\'#archivedmilesort_\'+type);  }  milestoneSort("archived",type,sortEle);  });  if("home"!="${PAGEFOR}")  {  if("bugs"=="${MODTYPE}")  {  if("template"=="${PROJSTATUS}" || "template_deactive"=="${PROJSTATUS}")  {  modifyURL("tempmilestones/${PROJID}");  }  else  {  modifyURL("bugmilestones/${PROJID}");  }    }  else  {  if("template"=="${PROJSTATUS}" || "template_deactive"=="${PROJSTATUS}")  {  modifyURL("tempmilestones/${PROJID}");  }    }  } else {  jQuery("#classicview").click(function() {  ShowGenInline("ajax_load_tab");  loadTaskModule(\'0\',null,task_constants.VIEWTYPES.TABLE,task_constants.GROUPBY.TASKLIST);  });  jQuery("#plainview").click(function() {  ShowGenInline("ajax_load_tab");  loadTaskModule(\'0\',null,task_constants.VIEWTYPES.TABLE,task_constants.GROUPBY.NONE);  });  if("bugs"=="${MODTYPE}")  {  modifyURL("mybugsmilestones");  }  else  {  modifyURL("mymilestones");  }  highlightMenuItem(\'Milestone\');  ProjectTabs.paintSingularTabHeader(getI18nValue(\'zp.general.milestones\'));  }  var filterObj = zpfilters.getListViewFilterObj("${PROJID}","milestone");  if(filterObj != null && !jQuery.isEmptyObject(filterObj))  {  jQuery(\'#mempdiv img\').attr(\'src\',getCdnUrl(\'img\',\'images/svg/emptylargeicon/empty_state_search_not_found.svg\'));  }  function callbackAlways()  {  fixedTopLayer("milestone");  }  getMoreOnScroll(null,null,"vertical",callbackAlways); <\/script> {{if NEWMILEVIEW}}  <script>  if (jQuery("#mileNewDisp").children().length === 0){  var jsData = {};  jsData.PROJID = "${PROJID}";jsData.MODTYPE="${MODTYPE}";jsData.PAGEFOR="${PAGEFOR}";jsData.ISDATEBASED="${ISDATEBASED}";jsData.PROJNAME="${PROJNAME}";jsData.CONTPATH=Utils.contPath;jsData.PROJSTAT="${PROJSTATUS}";jsData.ISTEMPLATE="${ISTEMPLATE}";jsData.ISTASKTABENABLED="${ISTASKTABENABLED}";jsData.ISBUGTABENABLED="${ISBUGTABENABLED}";jsData.ISBUDGETENABLED="${ISBUDGETENABLED}"; jsData.PERCENTTYPE="${PERCENTTYPE}";  jsData.has_primary_client="${has_primary_client}";  jQuery("#mileNewDisp").html(jQuery.tmpl("milenewview",jsData));   }  <\/script>  {{/if}}   ',window.miledatadisplay='{{if MSOBJ}} {{each(i,MOBJ) MSOBJ}}  <tr id="delmilefeat_${MOBJ.MID}" name = "mrow_${MSTYPE}" class="module_list {{if permissions.tag.permission.view}}zps-tagsarrow{{/if}}" {{if "completed"!=MSTYPE && "archived"!=MSTYPE && (MOBJ.MSEDITALLPERM=="true" || (MOBJ.MZUID==LOGINNAME && MOBJ.MSEDITPERM=="true")) && PROJSTAT!="archived" && PROJSTAT!="template"}} onmouseover="ShowGenInline(\'milefl_${MOBJ.MID}\');" onmouseout="Hide(\'milefl_${MOBJ.MID}\');"{{/if}}>  <td>  <div class="first-cell-container">  <span class="zps-mlt-rowaction">  {{if (MOBJ.MSEDITALLPERM=="true" || (MOBJ.MZUID==LOGINNAME && MOBJ.MSEDITPERM=="true")) || (MOBJ.MSDELETEALLPERM=="true" || (MOBJ.MZUID==LOGINNAME && MOBJ.MSDELETEPERM=="true"))}}    <i class="zoho-ellipsis icta" data-connecteddom="true" data-tooltip-pos="bottom-left" onclick="moveMilePopDivCommon(\'${MOBJ.MID}\');" name = "milediv_${MILETYPE}" tour="mlt-row-edit"></i>    <input type="hidden" value="${MOBJ.MPNAME}" name="${MOBJ.MID}_projNameJson" id="${MOBJ.MID}_projNameJson">    <div id="mileaction_${MOBJ.MID}" class="with-list-icon maxw300 minw200 hide" name="mileactiondiv">  {{if "completed"!=MSTYPE && "archived"!=MSTYPE}}  <div class="popuplist" tabindex="0" ellipsis="true" data-tooltip="${getI18nValue(\'zp.general.edit\')}" onclick="javascript:jsonConstuctPage(Utils.contPath+\'/constupdmile.do\',\'projId=${MOBJ.MPID}&mid=${MOBJ.MID}&mflag=${MOBJ.MSFLAG}&modtype=${MODTYPE}&pagefor=${PAGEFOR}&${getZPCSRF()}\',\'editmilestoneform\',\'html\',\'delmilefeat_${MOBJ.MID}\',\'\',\'${MOBJ.MPID}\');"><i class="zoho-edit"></i>${getI18nValue(\'zp.general.edit\')}</div>  {{/if}}  {{if (MOBJ.MSDELETEALLPERM=="true" || (MOBJ.MZUID==LOGINNAME && MOBJ.MSDELETEPERM=="true")) }} <div class="popuplist" tabindex="0" ellipsis="true" data-tooltip="${getI18nValue(\'zp.general.trash\')}" onclick="miledetaildelete(\'${MOBJ.MPID}\',\'${MOBJ.MID}\',\'${MODTYPE}\',\'${getI18nValueWithParams("zp.functionjs.newdelmile", [Utils.milestoneSingularValue, Utils.taskPluralValue])}\')"><i class="zoho-trash"></i><span>${getI18nValue(\'zp.general.trash\')}</span></div>  {{/if}}  {{if "completed"!=MSTYPE && "archived"!=MSTYPE}}  {{if (MOBJ.MSEDITALLPERM=="true" && MOBJ.MSEDITPERM=="true")}}  <div class="popuplist" tabindex="0" ellipsis="true" data-zpqa="mileqa_movelist_${MOBJ.MID}" data-tooltip="${getI18nValue(\'zp.doc.move\')}" onclick="moveMilestone(\'${MOBJ.MPID}\',\'${MOBJ.MID}\')"><i class="zoho-move"></i>${getI18nValue(\'zp.doc.move\')}</div>  {{/if}}    {{if !(MOBJ.PROJSTAT && ("template"==MOBJ.PROJSTAT || "template_deactive"==MOBJ.PROJSTAT))}}  {{if MOBJ.MSTASKVIEWALLPERM=="true" && MOBJ.MSBUGVIEWALLPERM=="true"}}  <div class="popuplist" tabindex="0" ellipsis="true" id="flw_mile_${MOBJ.MID}" data-zpqa="mileqa_flwlist_${MOBJ.MID}" data-tooltip="${getI18nValue(\'zp.project.follow\')}" onclick="followMilestone(\'${MOBJ.MPID}\',\'${MOBJ.MID}\', ${MOBJ.ISFOLLOW})"><i class="zoho-com-follow"></i><span>{{if MOBJ.ISFOLLOW}}${getI18nValue(\'zp.project.unfollow\')}{{else}}${getI18nValue(\'zp.project.follow\')}{{/if}}</span></div>  {{/if}}    <div class="popuplist" tabindex="0" ellipsis="true" data-tooltip="${getI18nValue(\'zp.reports.complete\')}" onclick="javascript:milestoneComplete(\'${MOBJ.MPID}\',\'${MOBJ.MID}\',function(){if(isMileDateCheck(\'${MCURTIME}\',\'${MSTIME}\',this)){ document.getElementById(\'delmilefeat_${MOBJ.MID}\').parentNode.removeChild(document.getElementById(\'delmilefeat_${MOBJ.MID}\'));}ajaxRenderJson(Utils.contPath+\'/compmilestone.do\',\'mid=${MOBJ.MID}&status=2&modtype=${MODTYPE}&projId=${MOBJ.MPID}&pagefor=${PAGEFOR}&${getZPCSRF()}\',\'miledatadisplay\',\'html\',\'\',\'${MOBJ.MID}\',\'${MOBJ.MPID}\');});"><i class="zoho-complete-project"></i>${getI18nValue(\'zp.reports.complete\')}</div>  {{/if}}  {{/if}}    {{if !(MOBJ.PROJSTAT && "template"==MOBJ.PROJSTAT)}}  {{if "completed"==MSTYPE}}  {{if (MOBJ.MSEDITALLPERM=="true" || (MOBJ.MZUID==LOGINNAME && MOBJ.MSEDITPERM=="true")) }} <div class="popuplist" tabindex="0" ellipsis="true" data-tooltip="${getI18nValue(\'zp.projpage.archive\')}" onclick="javascript:Hide(\'delmilefeat_${MOBJ.MID}\');document.getElementById(\'delmilefeat_${MOBJ.MID}\').parentNode.removeChild(