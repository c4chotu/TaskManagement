n-name" ellipsis="true" data-tooltip="{{html getI18nValueWithParam(CUSTOMDETAIL.ALIASNAME, [Budget.base_currency_code])}}" customfield="${CUSTOMDETAIL.PCFID}">{{html getI18nValueWithParam(CUSTOMDETAIL.ALIASNAME, [Budget.base_currency_code])}}</div>  {{else}}  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${CUSTOMDETAIL.ALIASNAME}" customfield="${CUSTOMDETAIL.PCFID}">  {{if CUSTOMDETAIL.COLUMNNAME == "BASELINE"}}  <div class="export-column-with-label">  <span data-tooltip="${CUSTOMDETAIL.ALIASNAME}" ellipsis="true">${CUSTOMDETAIL.ALIASNAME}</span>  <span class="expbaseline-name" data-tooltip="${CUSTOMDETAIL.BASELINE_NAME}" ellipsis="true">${CUSTOMDETAIL.BASELINE_NAME}</span>  </div>  {{else}}  ${CUSTOMDETAIL.ALIASNAME}  {{/if}}  </div>   {{/if}}  <i id="news" class="move-right-action zoho-right-arrow-plain" onclick="taskExportDragableColumns(this); "></i>  </div>  {{/if}}    {{if CUSTOMDETAIL.COLUMNNAME =="TODOLISTTITLE" || CUSTOMDETAIL.COLUMNNAME=="MILESTONETITLE"}}  {{if CUSTOMDETAIL.ISVISIBLE == 0 || !taskListViewExtensions.isPlain()}}  {{if CUSTOMDETAIL.COLUMNNAME=="TODOLISTTITLE"}}  <div class="export-column-list optsel" id="60" columnid="60" columntype="left">  <div id="pickVal_60" class="export-column-name" ellipsis="true" data-tooltip="${getI18nValue(\'zp.dependview.tasklist\')}" customfield="60">${getI18nValue(\'zp.dependview.tasklist\')}</div>  <i id="news" class="move-right-action zoho-right-arrow-plain" onclick="taskExportDragableColumns(this); "></i>   </div>  {{/if}}    {{if CUSTOMDETAIL.COLUMNNAME=="MILESTONETITLE"}}  <div class="export-column-list optsel" id="${CUSTOMDETAIL.PCFID}" columnid="${CUSTOMDETAIL.PCFID}" columntype="left">  <div id="pickVal_${CUSTOMDETAIL.PCFID}" class="export-column-name" ellipsis="true" data-tooltip="${getMileRepValue(\'zp.dependview.milestone\',\'single\')}" customfield="${CUSTOMDETAIL.PCFID}">${getMileRepValue(\'zp.dependview.milestone\',\'single\')}</div>   <i id="news"