GlobalAdd.Import = {
    constructImportForms: function (module , projId) {
        UI.Utils.empty("#globalAddDiv");//NO I18N
        if(module === GlobalAdd.Constants._TASK){
            showJsonImportPage(projId,'0',undefined,'viewbygrp','globalAddDiv');
        }else if(module === "Jira"){//NO I18N
			import('/asset/setup/data-administration-util').then((mod) => {    //no i18n
				mod.Imports.jira.setup('#globalAddDiv');  //no i18n
			});
        }else if(module === "Basecamp"){//NO I18N
			import('/asset/setup/data-administration-util').then((mod) => {    //no i18n
				mod.Imports.baseCamp.setup('#globalAddDiv');   //no i18n
			});
        }else if(module === "IssueImport"){//NO I18N
			importIssueRoute().then(mod => {
           		GlobalAdd.Import.loadIssueImportForm('bugtracker');//NO I18N
			});
        }else if(module === "ImportFromOthers"){//NO I18N
			// jQuery("#globalAddDiv").html();
        }

    },
    
    openImportedProj: function(projectId){
		const projectTabs = new ProjectTabs ({isProjectTabsVisible: true, projectId: projectId, niceURLFromPage: 'tasks'}) // NO I18N
		projectTabs.makeAjaxCalls()
		constructProjDisplayPage(projectId)	
		goToSavedTaskView(projectId,getZPCSRF())
	},
    
    loadIssueImportForm: function (module){
        jQuery("#globalAddDiv").html(jQuery.tmpl("bugimport", {'comp' : "importtemplate"})).show().promise().done(function(){ // no i18n
    		
            GlobalAdd.Utils.loadProjectBar('bugImportProj', GlobalAdd.Constants._BUG);// no i18n
    		
            jQuery("#bugimport").submit(function(e){
                return false;
            });
            document.getElementById("bug_upload_file").addEventListener('click', function() {
				var projectId = GlobalAdd.States.Project.id;
                document.getElementById('bug_upload_file').setAttribute("zps-loader", "yes");
                if(!jQuery('#uploadfile').val()){
                    var errorMsg = {'message' : getI18nValue('zp.impmpp.empty')} // no i18n
                    UI.Utils.showError(errorMsg);
                    document.getElementById('bug_upload_file').setAttribute("zps-loader", "no");
                    attentionClick('id','bug_upload_file'); // no i18n
                    return false;
				}
				
				if(projectId == "0" || projectId == ""){
					attentionClick("id", "bug_upload_file_cancel");//No I18N                    		
					UI.Utils.showError({'message':getI18nValue('zp.timesheet.validproject')});//No I18N
					document.getElementById('bug_upload_file').setAttribute("zps-loader", "no");
					attentionClick('id','bug_upload_file'); // no i18n
					return false;			
				}
                var selFileName = jQuery("[name='filetype']:checked").val();
    			
                var filename = jQuery("#uploadfile").val();
                var orgFileType = filename.substring(filename.lastIndexOf(".") + 1);
                if(orgFileType === 'xlsx'){
                    orgFileType='xls';//no i18n
                }
                if(!filename.match(/[.]csv$/i) && !filename.match(/[.]xls$/i) && !filename.match(/[.]xlsx$/i))
                {
                    var errorMsg = {'message' : 'zp.files.importxlsandcsvonly'} // no i18n
                    UI.Utils.showError(errorMsg);
                    document.getElementById('bug_upload_file').setAttribute("zps-loader", "no");
                    attentionClick('id','bug_upload_file'); // no i18n
                    return false;
                }
                else if (!(selFileName.toLowerCase() === orgFileType.toLowerCase()))
                {
                    if('xls'==orgFileType){
                        jQuery('#lable_csv').prop("checked",false); // no i18n
                        jQuery('#lable_xls').prop("checked",true); // no i18n
                    }else if('csv'==orgFileType){ // no i18n
                        jQuery('#lable_xls').prop("checked",false); // no i18n
                        jQuery('#lable_csv').prop("checked",true); // no i18n
                    }
                }
    			
                var form = jQuery("#bugimport"); 
                var formData = new FormData(jQuery('#bugimport')[0]);
                var uploadFileUrl = "/projects/"+projectId+"/bugs/import/uploadfile/"; // no i18n
    	    	
                ajaxRequest({url: uploadFileUrl,  type: 'POST', args: formData,processData: false,contentType:false,restAPI: true}).then(function(uploadFileResponseData){ // no i18n
                    let resp = uploadFileResponseData.data;
                    if(resp.error_msg!=null){
                        var errorMsg = {'message' : resp.error_msg} // no i18n
                        UI.Utils.showError(errorMsg); 
                        document.getElementById('bug_upload_file').setAttribute("zps-loader", "no");
                        attentionClick('id','bug_upload_file'); // no i18n
                        return;
                    }
                    document.getElementById('bug_upload_file').setAttribute("zps-loader", "no");
                    resp.comp = 'field_mapping'; // no i18n
                    jQuery('#upload_file').addClass('hide');
                    jQuery('#field_map').html(jQuery.tmpl('bugimport',resp)); // no i18n
                    jQuery('#field_map').removeClass('hide');
                    jQuery("#mapbugimportscroll").off("scroll").on("scroll",function(){ // no i18n
                                    if(jQuery(".zdropdownlist")){
                                        jQuery(".zdropdownlist").hide();
                                    }
                    });
                    document.getElementById("schedule_import").addEventListener('click', function() {
                        var projectId = zpselectcomponent.getValue(document.getElementById("bugImportProj"));
                        document.getElementById('schedule_import').setAttribute("zps-loader", "yes");
                        var scheduleform = jQuery("#mapbugimportfield"); 
                        var bugimpformData = new FormData(jQuery('#mapbugimportfield')[0]);
                        var impScheduleUrl = "/projects/"+projectId+"/bugs/import/schedule/"; // no i18n
                        ajaxRequest({url: impScheduleUrl,  type: 'POST', args:bugimpformData,processData: false,contentType:false,restAPI: true}).then(function(scheduleImportResponseData){ // no i18n
                                resp = scheduleImportResponseData.data;
                                if(resp.error_msg!=null){
                                    var errorMsg = {'message' : resp.error_msg} // no i18n
                                    UI.Utils.showError(errorMsg); 
                                    document.getElementById('schedule_import').setAttribute("zps-loader", "no");
                                    attentionClick('id','schedule_import'); // no i18n
                                    return;
                                }
                                document.getElementById('schedule_import').setAttribute("zps-loader", "no");
                                resp.comp = 'bug_imp_status'; // no i18n
                                jQuery('#upload_file').addClass('hide');
                                jQuery('#field_map').addClass('hide');
                                jQuery('#bugimpstatus').html(jQuery.tmpl('bugimport',resp)); // no i18n
                                jQuery('#bugimpstatus').removeClass('hide');
                                setTimeout(function(){
                                     if(GlobalAdd.CallFrom.GA != undefined && GlobalAdd.CallFrom.GA === 'yes'){
                                         GlobalAdd.Actions.close();
										 const spanFragment = document.createDocumentFragment();
                                         const spanElementProj = createAndSetAttributes('span') //NO I18N
                                         spanElementProj.textContent = getI18nValue('zp.issueimport.successful') //NO I18N
                                         spanFragment.appendChild(spanElementProj)
                                         //const linkProj = createAndSetAttributes('a', { class: 'zps-success-link' }) //NO I18N
                                         //linkProj.textContent = getI18nValue('zp.general.viewnow') //NO I18N
                                         //linkProj.addEventListener("click", function () { GlobalAdd.Modules.IssueImport.viewEntity(projectId) });
                                         //spanFragment.appendChild(linkProj);
                                         
										 UI.Utils.showSuccess({ message: spanFragment, time: 5000 });
                                     }
                                },5000);
                            }) 
                    });
    				
                    document.getElementById("cancel_import").addEventListener('click', function() {
                        GlobalAdd.Actions.close();
                    });
                })
            });
            document.getElementById("bug_upload_file_cancel").addEventListener('click', function() {
                GlobalAdd.Actions.close();
            });
        });
    },

	openOtherImports: function (){
		const url = "https://creatorapp.zohopublic.in/uprasanna_zohocorp/data-migration/form-perma/Data_Migration/Hdx5tWHzvhrCaKGkkXKfjesye0XZNreQwnbSWXTjEauj3qkrHngVEsukMVOn2hOuHdMz5zz3znNuYjj118xKQXzkGqKMsUfnpSMv";// no i18n
		window.open(url, "_blank");
	}

}

GlobalAdd.Data = {
	EnabledModules: function (projectId) {
		return ajaxRequest({
			url: Utils.contPath + '/dashwizard.do', //NO I18N
			type: _POST,
			args: {
				frompage: 'gadd', //NO I18N
				projId: projectId
			},
			restAPI: false
		})
	}
}

