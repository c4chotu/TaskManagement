//$Id$
var GlobalAdd = {}

GlobalAdd.CallFrom = {
	GA: 'no',	//no i18n
	Leftpanel: false,
	Calendar: false
}

GlobalAdd.States = {
	Project: {
		id: '0',
		name: getI18nValue('zp.general.gotoproj') //NO I18N 
	},
	ProjectId: '0',
	AddData: {},
}

GlobalAdd.Constants = {
	_TASK: 'Task', //NO I18N
	_BUG: 'Issues', //NO I18N
	_TIMESHEET: 'Timesheet', //NO I18N
	_PROJECT: 'Project', //NO I18N
	_USER: 'Users', //NO I18N
	_MILESTONE: 'Milestone', //NO I18N
	_TASKLIST: 'TaskList', //NO I18N
	_FORUM: 'Forum', //NO I18N
	_EVENT: 'Event', //NO I18N
	_DOCUMENT: 'Document', //NO I18N
	_TIMEOFF: 'TimeOff', //NO I18N
	_ZOHOMEETING: 'ZohoMeeting', //NO I18N
	_LOADING: 'Loading', //NO I18N
	ImportSet: new Set(['TaskImport', 'IssueImport', 'JiraImport', 'BasecampImport', 'ImportFromOtherSource']), //NO I18N
	WPExcludeModules: new Set(['JiraImport', 'BasecampImport', 'ImportFromOtherSource']), //No i18n
	Container: 'globalAddDiv', //NO I18N
	ContainerSelector: '#globalAddDiv',//NO I18N
	isGAPublicProject: false,
}
   if (Utils.isTabMigrated) {
	    GlobalAdd.Constants.ModuleSet = new Set(['Task', 'Issue', 'Timesheet', 'Project', 'Users', 'Milestone', 'TaskList', 'Forum', 'Event', 'Documents', 'TimeOff', 'Loading', 'TaskImport', 'IssueImport', 'JiraImport', 'BasecampImport', 'ImportFromOtherSource']); //NO I18N
		GlobalAdd.Constants.ViewerHdnModuleSet = new Set(['Issue', 'Timesheet', 'Milestone']); //NO I18N
	} else {
	    GlobalAdd.Constants.ModuleSet= new Set(['Task', 'Issues', 'Timesheet', 'Project', 'Users', 'Milestone', 'TaskList', 'Forum', 'Event', 'Document', 'TimeOff', 'Loading', 'TaskImport', 'IssueImport', 'JiraImport', 'BasecampImport', 'ImportFromOtherSource']); //NO I18N
		GlobalAdd.Constants.ViewerHdnModuleSet= new Set(['Issues', 'Timesheet', 'Milestone']); //NO I18N
	}

GlobalAdd.Observers = {
	LoadingObserver: function (mutationRecords) {
		const globalAddElement = document.getElementById(GlobalAdd.Constants.Container)

		// Multiple cancel buttons are possible
		const cancelElements = globalAddElement.querySelectorAll('.cancel-button') //NO I18N
		cancelElements.forEach(function (cancelElement) {
			cancelElement.addEventListener('click', GlobalAdd.Events.close)
		})

		if (globalAddElement.childElementCount == 0) {
			GlobalAdd.Utils.showLoading()
		} else {
			GlobalAdd.Utils.hideLoading()
		}
	}
}

const _GLOBAL_ADD_OBSERVER = new MutationObserver(GlobalAdd.Observers.LoadingObserver)

GlobalAdd.Actions = {
	/**
	 * directOpen will open the global add form if the user has permission to 
	 * add the module data in that project
	 * 
	 * If the user doesn't have permission, there'll be no UI reflection
	 */
	directOpen: function (moduleToLoad) {
		if (Utils.isVcrmPartnerOrClient || moduleToLoad == undefined || !GlobalAdd.Constants.ModuleSet.has(moduleToLoad)) {
			return
		}

		// If the user is NOT inside a project and the project Id in the state is different
		// Set that projectId
		// For calendar always set the current project Id as 0

		let currentProjectId = '0'
		if (ProjectConstants.get('projectStatus') == 'active') {
			currentProjectId = ProjectConstants.get('_currentProjectID') || '0'
		}
		if (currentProjectId == '0' && GlobalAdd.States.Project.id != '0') {
			currentProjectId = GlobalAdd.States.Project.id
		}

		GlobalAdd.Utils.getEnabledModules(currentProjectId)
			.then(function (moduleSet) {
				if (!moduleSet.has(moduleToLoad)) {
					return
				}

				GlobalAdd.Utils.constructMenu(moduleSet)

				const iconElement = document.getElementById('global-menu-icon')
				iconElement.addEventListener('mouseover', GlobalAdd.Events.showMenu)

				const formElement = document.getElementById(GlobalAdd.Constants.Container)
				formElement.addEventListener('mouseover', GlobalAdd.Events.hideMenu)

				// In CRMPlus, both forms can be open at a time, so therefore closing the
				// normal form before loading the global add form
				UI.Utils.unloadForm()

				UI.Utils.addClass('#global-add-container', 'show-main-form')
				UI.Utils.empty(GlobalAdd.Constants.ContainerSelector)
				UI.Utils.freezeScreen(true)

				const globalAddElement = document.getElementById(GlobalAdd.Constants.Container)
				_GLOBAL_ADD_OBSERVER.observe(globalAddElement, { childList: true, subtree: true })

				GlobalAdd.CallFrom.GA = 'yes' //NO I18N

				GlobalAdd.Utils.loadModule(moduleToLoad)
			})
	},
	open: function (moduleToLoad, showMenu, fromCalendar = false, dateObject) {
		GlobalAdd.Utils.showLoading()
		// Global add is not available for VCRM
		if (!fromCalendar && Utils.isVcrmPartnerOrClient) {
			return
		}
		showMenu = (showMenu !== undefined) ? showMenu : true

		let currentProjectId = '0'
		if (ProjectConstants.get('projectStatus') == 'active') {
			currentProjectId = ProjectConstants.get('_currentProjectID') || '0'
		}
		//To add mics entry for the number of clicks
		LayoutUtils.logRecentAccess(undefined, "Global_add"); //NO I18N
		// If the user is NOT inside a project and the project Id in the state is different
		// Set that projectId
		// For calendar always set the current project Id as 0
		if (!fromCalendar && currentProjectId == '0' && GlobalAdd.States.Project.id != '0') {
			currentProjectId = GlobalAdd.States.Project.id
		}

		if (fromCalendar) {
			GlobalAdd.CallFrom.Calendar = true
		}

		// In CRMPlus, both forms can be open at a time, so therefore closing the
		// normal form before loading the global add form
		UI.Utils.unloadForm()

		// Open the form immediately, let the user know that the form is loading
		UI.Utils.addClass('#global-add-container', 'show-main-form')
		UI.Utils.empty(GlobalAdd.Constants.ContainerSelector)
		UI.Utils.freezeScreen(true)

		GlobalAdd.Utils.getEnabledModules(currentProjectId)
			.then(function (moduleSet) {
				if (showMenu) {
					GlobalAdd.Utils.constructMenu(moduleSet)

					const iconElement = document.getElementById('global-menu-icon')
					iconElement.addEventListener('mouseover', GlobalAdd.Events.showMenu)
					iconElement.addEventListener('click', GlobalAdd.Events.showMenu)

					const formElement = document.getElementById(GlobalAdd.Constants.Container)
					formElement.addEventListener('mouseover', GlobalAdd.Events.hideMenu)

					UI.Utils.removeClass('#global-menu-icon', 'hide')
				} else {
					UI.Utils.addClass('#global-menu-icon', 'hide')
				}

				// Take the first module in the module set. Entries in the set is returned 
				// in a defined order. See the method getEnabledModules() for the order
				moduleToLoad = (moduleToLoad) ? moduleToLoad : moduleSet.values().next().value
				if (moduleToLoad == undefined || moduleSet.size == 0 || !moduleSet.has(moduleToLoad)) {
					UI.Utils.showError({ message: 'zp.ajaxjs.perdenied' }) //NO I18N
					GlobalAdd.Actions.close()
					return
				}

				const globalAddElement = document.getElementById(GlobalAdd.Constants.Container)
				_GLOBAL_ADD_OBSERVER.observe(globalAddElement, { childList: true, subtree: true })

				GlobalAdd.CallFrom.GA = 'yes' //NO I18N

				if (dateObject && dateObject.startDate) {
					globalAddElement.setAttribute('data-start-date', dateObject.startDate)
					globalAddElement.setAttribute('data-start-date-time', dateObject.startDateWithTime)
					globalAddElement.setAttribute('data-end-date', dateObject.endDate)
					globalAddElement.setAttribute('data-end-date-time', dateObject.endDateWithTime)
					let startDateTime = moment(dateObject.startDateWithTime, Utils.moment.datetimeformat.replace('aaa', 'a')).toDate();
					let endDateTime = moment(dateObject.endDateWithTime, Utils.moment.datetimeformat.replace('aaa', 'a')).toDate();
					if ((endDateTime - startDateTime) / (1000 * 60 * 60 * 24) === 1) {
						endDateTime.setMinutes(-1);
					}
					let modifiedEnd = formatDate(endDateTime, Utils.datetimeformat.replace('aaa', 'a'));
					if (Utils.timeformat.endsWith('aaa')) {
						globalAddElement.setAttribute('timer-extra-data', "(" + moment(dateObject.startDateWithTime, Utils.moment.datetimeformat).format("hh:mm A") + " - " + moment(modifiedEnd, Utils.moment.datetimeformat).format("hh:mm A") + ")");
					}
					else {
						globalAddElement.setAttribute('timer-extra-data', "(" + moment(dateObject.startDateWithTime, Utils.moment.datetimeformat).format(Utils.timeformat) + " - " + moment(modifiedEnd, Utils.moment.datetimeformat).format(Utils.timeformat) + ")");
					}
				}
				GlobalAdd.Utils.loadModule(moduleToLoad)
				GlobalAdd.Utils.hideLoading()
			})
			.catch(function (error) {
				UI.Utils.showError()
				console.error(error)
			})

	},
	openProjectFromTgallery: function () {
		let moduleName = 'Project' //NO I18N
		if (document.getElementById("empty_timer_log_form") != null && document.getElementById("editlogHours") == null) {
			document.getElementById("empty_timer_log_form").remove();
		}
		GlobalAdd.Utils.loadModule(moduleName)
	},
	close: function () {
		const globalAddElement = document.getElementById(GlobalAdd.Constants.Container)
		globalAddElement.removeAttribute('data-current-module')
		globalAddElement.removeAttribute('data-start-date')
		globalAddElement.removeAttribute('data-start-date-time')
		globalAddElement.removeAttribute('data-end-date')
		globalAddElement.removeAttribute('data-end-date-time')
		GlobalAdd.CallFrom.GA = 'no' //NO I18N
		GlobalAdd.CallFrom.Calendar = false
		_GLOBAL_ADD_OBSERVER.disconnect()
		UI.Utils.empty(GlobalAdd.Constants.ContainerSelector)
		UI.Utils.freezeScreen(false)
		UI.Utils.removeClass('#global-add-container', 'show-main-form')
		document.getElementById("zpsPopDefault").setAttribute("isonga", false);
	}
}

GlobalAdd.Events = {
	open: function (event) {
		if (zpApp.$router.getRouteInstance().routeName == 'wildcard') {
			modifyURLNoHistory(zpApp.$router.location.url.split('#')[1] + '?global_view=add');	//no i18n
		} else {
			zpApp.$router.getRouteInstance().setQueryParams({ global_view: 'add' });	//no i18n
		}
	},
	close: function (event) {
		GlobalAdd.Actions.close();

		if (zpApp.$router.getRouteInstance().routeName == 'wildcard') {	//no i18n
			let urlQp = zpApp.$router.location.url.split('?')[1];	//no i18n
			modifyURLNoHistory(zpApp.$router.location.url.split('#')[1].replace('?' + urlQp, ''));	//no i18n
		} else if(zpApp.$router.location.url.contains('global_view=add')){	//no i18n
			let qPObj = zpApp.$router.getRouteInstance().getQueryParams();
			zpApp.$router.getRouteInstance().setQueryParams({...qPObj, ...{ global_view : undefined, module : undefined }});
		}
	},
	showMenu: function (event) {
		GlobalAdd.Utils.showMenu()
	},
	hideMenu: function (event) {
		GlobalAdd.Utils.hideMenu()
	},
	menuClick: function (event) {
		let target = event.target
		target = target.closest('.global-items') //NO I18N
		if (target == undefined) {
			return
		}
		const moduleName = target.getAttribute('global-add-module')
		GlobalAdd.Utils.hideMenu()

		if (document.getElementById("empty_timer_log_form") != null && document.getElementById("editlogHours") == null) {
			document.getElementById("empty_timer_log_form").remove();
		}

		GlobalAdd.Utils.loadModule(moduleName)
	},
	onProjectChange: function (event, data) {
		let projectId = data.value
		let projectName
		let globalAddDiv = document.getElementById('globalAddDiv')
		let moduleName = globalAddDiv.getAttribute('data-current-module')
		let module = GlobalAdd.Utils.getModule(moduleName)

		if (projectId == "" || projectId == '0' || projectId == '-1') {
			projectId = '0'
			projectName = getI18nValue('zp.general.gotoproj') //NO I18N 
			data.optionData = {
				id: projectId,
				name: projectName
			}
			jQuery(data.element).val('0')
		} else {
			projectName = data.optionData.name
		}
		GlobalAdd.Utils.setProject(projectId, projectName)
		module.onProjectChange && module.onProjectChange(data.optionData, event, data)
	},
	viewLinkClick: function (event) {
		if (GlobalAdd.States.AddData != undefined) {
			let moduleName = event.target.getAttribute('data-current-module')
			const module = GlobalAdd.Utils.getModule(moduleName)
			module.viewEntity && module.viewEntity(GlobalAdd.States.AddData)
			GlobalAdd.Events.closeSuccessMessage()
		}
	},
	getEntityUrl: function (moduleName, data) {
		const module = GlobalAdd.Utils.getModule(moduleName);
		if (module && module.getLink) {
			const link = module.getLink(data);
			if (link) {
				let location = zpApp.$router.location;
				return location.origin + location.pathname + "#" + link; //NO I18N
			}
		}
		return null;
	},
	closeSuccessMessage: function () {
		UI.Utils.closeToast('success'); //NO I18N
		GlobalAdd.States.AddData = {}
	}
}

GlobalAdd.Utils = {
	loadProjectBar: function (selectElementId, moduleName, userId) {
		let module = GlobalAdd.Utils.getModule(moduleName)
		if (selectElementId == undefined || module == undefined || document.getElementById(selectElementId) == undefined) {
			console.error('select element and module name is mandatory')  //NO I18N
		}
		let permissionName = module.getPermissionName()
		let selectedProject = GlobalAdd.Utils.getProject()
//		moduleName == 'Issues' ? selectedProject =  : '';
		zpselectcomponent.destroy(document.getElementById(selectElementId))
		zpselectcomponent.init(document.getElementById(selectElementId), selectedProject, {
			selectOptions: {
				placeholder: getI18nValue('zp.general.gotoproj'), //NO I18N
				change: function (event, data) {
					GlobalAdd.Events.onProjectChange(event, data)
				},
			},
			providerWrapper: ProviderRepository.getNamedProviderWrapper('GLOBAL_ADD_PROJECT_' + moduleName, projectsProviderConstants.PROJECTS,  //NO I18N
				{ module: permissionName, permission: 'create' }, { range: 100 }), //NO I18N
			customContent: projectCustomContent,
		})
	},
	showMenu: function () {
		UI.Utils.addClass('#global-menu', 'gform-menu-show')
	},
	hideMenu: function () {
		UI.Utils.removeClass('#global-menu', 'gform-menu-show')
	},
	showLoading: function () {
		UI.Utils.removeClass('#global-loading', 'hide')
	},
	hideLoading: function () {
		UI.Utils.addClass('#global-loading', 'hide')
	},
	getModule: function (moduleName) {
		return GlobalAdd.Modules[moduleName]
	},
	getStartDate: function () {
		const globalAddElement = document.getElementById(GlobalAdd.Constants.Container)
		return globalAddElement.getAttribute('data-start-date')
	},
	getStartDateWithTime: function () {
		const globalAddElement = document.getElementById(GlobalAdd.Constants.Container)
		return globalAddElement.getAttribute('data-start-date-time')
	},
	getEndDate: function () {
		const globalAddElement = document.getElementById(GlobalAdd.Constants.Container)
		return globalAddElement.getAttribute('data-end-date')
	},
	getEndDateWithTime: function () {
		const globalAddElement = document.getElementById(GlobalAdd.Constants.Container)
		return globalAddElement.getAttribute('data-end-date-time')
	},
	getProject: function () {
		let projectId = ProjectConstants.get('_currentProjectID')
		let projectName = ProjectConstants.get('_currentProjectName')
		if (GlobalAdd.Constants.isGAPublicProject) {
			projectId = '0';
			projectName = undefined;
		}
		// The user is in home page, but has already chosen a project
		// If the user is in a project page, that takes precedence
		if ((!projectId || projectId == '0') && GlobalAdd.States.Project.id != undefined && GlobalAdd.States.Project.name != undefined) {
			return GlobalAdd.States.Project
		}
		if (ProjectConstants.get('projectStatus') != 'active' || projectId == undefined || projectId == '0' || projectName == undefined) {
			projectId = '0'
			projectName = getI18nValue('zp.general.gotoproj') //NO I18N 
		}
		GlobalAdd.States.ProjectId = projectId
		GlobalAdd.States.Project.id = projectId
		GlobalAdd.States.Project.name = projectName
		return GlobalAdd.States.Project
	},
	setProject: function (projectId, projectName, force) {
		force = (force == undefined) ? false : force
		if (!force && GlobalAdd.CallFrom.GA != 'yes') {
			return
		}
		// It's the same we're not updating it
		if (GlobalAdd.States.ProjectId == projectId) {
			return
		}
		GlobalAdd.States.ProjectId = (projectId) ? projectId : '0'
		GlobalAdd.States.Project.id = projectId
		GlobalAdd.States.Project.name = projectName
		GlobalAdd.Utils.loadMenu(GlobalAdd.States.ProjectId)
	},
	entityUpdated: function (data) {
		// Close the form
		GlobalAdd.Actions.close();
		const module = GlobalAdd.Utils.getModule(data.module)
		let responseForCalendar = module.formatResponseForCalendar(data.data)
		updateEntityToCalendar('edit', responseForCalendar)//No i18n
	},
	entityAdded: function (data) {
		const module = GlobalAdd.Utils.getModule(data.module)

		GlobalAdd.CallFrom.Calendar ? calendarCallback(data) : normalCallback(data)

		let closeForm = (data.close == undefined) ? true : data.close
		if (closeForm) {
			// Close the form
			GlobalAdd.Actions.close()
			GlobalAdd.Events.close();
		}


		function calendarCallback(data) {
			

			let successMessage = module.getSuccessMessage(data);
			// This is to ensure that last character of the success message
			// is a full stop. Certain i18n text may not have a full stop
			if (successMessage.charAt(successMessage.length - 1) != '.') {
				successMessage += '.'
			}
			const spanFragment = document.createDocumentFragment();	

			const spanElement = createAndSetAttributes('span') //NO I18N
			spanElement.textContent = successMessage
			spanFragment.appendChild(spanElement)
			GlobalAdd.States.AddData = data

			if (module.viewEntity) {
				const linkElement = createAndSetAttributes('a', { class: 'zps-success-link', 'data-current-module': data.module }) //NO I18N
				linkElement.textContent = getI18nValue('zp.general.viewnow') //NO I18N
				linkElement.addEventListener('click', GlobalAdd.Events.viewLinkClick)
				spanFragment.appendChild(linkElement)
			}

			if (module.viewEntity && module.getLink && module.getLink(data)) {
				spanFragment.appendChild(UI.Utils.createCopyLinkIcon(function () { return GlobalAdd.Events.getEntityUrl(data.module, data) }));
			}

			UI.Utils.showSuccess({ message: spanFragment, time: 6000 });
			sharedBasicCalendarView.refreshCalendarOnEntityUpdate(data.module);
		}

		function normalCallback(data) {

			const spanFragment = document.createDocumentFragment();	
				
			let successMessage = module.getSuccessMessage(data)
			// This is to ensure that last character of the success message
			// is a full stop. Certain i18n text may not have a full stop
			if (successMessage.charAt(successMessage.length - 1) != '.') {
				successMessage += '.'
			}
			const spanElement = createAndSetAttributes('span') //NO I18N
			spanElement.textContent = successMessage
			spanFragment.appendChild(spanElement)
			GlobalAdd.States.AddData = data

			if (module.viewEntity) {
				const linkElement = createAndSetAttributes('a', { class: 'zps-success-link', 'data-current-module': data.module }) //NO I18N
				linkElement.textContent = getI18nValue('zp.general.viewnow') //NO I18N
				linkElement.addEventListener('click', GlobalAdd.Events.viewLinkClick)
				spanFragment.appendChild(linkElement)
			}

			if (module.getLink && module.getLink(data)) {
				spanFragment.appendChild(UI.Utils.createCopyLinkIcon(function () { return GlobalAdd.Events.getEntityUrl(data.module, data) }));
			}

			UI.Utils.showSuccess({ message: spanFragment, time: 6000 });
		}
	},
	highlightModule: function (module) {
		const menuList = document.getElementById('global-menu')
		const existingActiveElement = menuList.querySelector('.global-items.active') //NO I18N
		if (existingActiveElement) {
			existingActiveElement.classList.remove('active') //NO I18N
		}
		const futureElement = menuList.querySelector('.global-items[global-add-module="' + module + '"]') // NO I18N
		if (futureElement) {
			futureElement.classList.add('active') //NO I18N
		}
		const displayName = GlobalAdd.Utils.getModule(module).getDisplayName()
		document.getElementById('global-current-module').textContent = displayName
	},
	loadModule: function (moduleName) {
		const moduleObject = GlobalAdd.Utils.getModule(moduleName)
		if (moduleObject == undefined || moduleName === GlobalAdd.Constants._LOADING || (moduleName == "Timesheet" && Utils.timeLogConfig.logType == 1)) {
			return
		}

		if(moduleName == 'ImportFromOtherSource'){
			moduleObject.load()
			return;
		}

		let data = {}
		data.projectId = GlobalAdd.Constants.isGAPublicProject ? '0' : GlobalAdd.Utils.getProject().id // get the project Id
		data.containerName = GlobalAdd.Constants.Container
		data.containerSelector = GlobalAdd.Constants.ContainerSelector

		GlobalAdd.CallFrom.GA = 'yes' //NO I18N

		const globalElement = document.getElementById(data.containerName)
		if (GlobalAdd.CallFrom.Calendar) {
			data.callFromCalendar = true
			data.startDate = globalElement.getAttribute('data-start-date')
			data.startDateWithTime = globalElement.getAttribute('data-start-date-time')
			data.endDate = globalElement.getAttribute('data-end-date')
			data.endDateWithTime = globalElement.getAttribute('data-end-date-time')
		} else {
			data.callFromCalendar = false
		}

		globalElement.setAttribute('data-current-module', moduleName)

		UI.Utils.empty(data.containerSelector)
		moduleObject.load(data)
		findSticky(".slideFormBottombtn") //NO I18N
		zpPopup.closePopup();
		GlobalAdd.Utils.highlightModule(moduleName)
	},
	loadMenu: function (projectId) {
		if (GlobalAdd.CallFrom.GA != 'yes') {
			return
		}
		GlobalAdd.Utils.getEnabledModules(projectId)
			.then(function (moduleSet) {
				GlobalAdd.Utils.constructMenu(moduleSet)
				let globalAddElement = document.getElementById(GlobalAdd.Constants.Container)
				let moduleName = globalAddElement.getAttribute('data-current-module')
				GlobalAdd.Utils.highlightModule(moduleName)
			})
			.catch(function (error) {
				console.error(error)
			})
	},
	constructMenu: function (moduleSet) {
		let menuList = document.getElementById('global-menu-list')
		let importMenuList = document.getElementById('global-menu-list-imports')
		menuList.innerHTML = '';importMenuList.innerHTML = '';
		let fragment = document.createDocumentFragment(); let fragmentImport = document.createDocumentFragment();
		let importsplit = document.getElementById('global-menu-importsplit');  
		importsplit.classList.contains('hide') ? importsplit.classList.remove('hide') : '';//NO I18N
		moduleSet.forEach(function (moduleName) {
			if (Utils.profileType == Utils.PROFILE_READONLY) {
				return
			}

			if((moduleName == "Issues" || moduleName=="Issue") && !Utils.bugVisibility){
				moduleSet.delete("IssueImport")//NO I18N
				return;
			}else if(moduleName == "Milestone" && !Utils.milestoneVisibility){//NO I18N
				return;
			}else if(moduleName == "Timesheet" && !Utils.timesheetVisibility){	//no i18n
				return;
			}else if(Utils.isSandboxPortal && moduleName == "JiraImport" ){//NO I18N
				return;
			}else if(Utils.isSandboxPortal && moduleName == "BasecampImport" ){//NO I18N
				return;
			}else if(Utils.isSandboxPortal && moduleName == "ImportFromOtherSource" ){//NO I18N
				return;
			}

			if(IsWPloaded && GlobalAdd.Constants.WPExcludeModules.has(moduleName)) {
				return;
			}
			

			const moduleObject = GlobalAdd.Utils.getModule(moduleName)
			let menuElement = createAndSetAttributes('span', { class: 'global-items', 'data-zpqa': 'global_add_' + moduleName , 'tabindex': 0}) //NO I18N

			if(moduleName == 'ImportFromOtherSource'){
				menuElement.classList.add('import-others-pmapp');//NO I18N
			}

			if (moduleName == "Timesheet" && Utils.timeLogConfig && Utils.timeLogConfig.logType == 1) {	//no i18n
				menuElement.setAttribute("disabled", true);
				menuElement.setAttribute("data-tooltip", getI18nValue('zp.timesheet.addLogDisabled.msg'))
			}

			if (GlobalAdd.Constants._LOADING === moduleName) {
				let textElement = createAndSetAttributes('span', { class: 'loading' }); //NO I18N
				menuElement.setAttribute('loading', 'true')
				menuElement.appendChild(textElement);
			} else {
				let textElement = createAndSetAttributes('span', { class: 'global-item-name', 'data-tooltip': moduleObject.getDisplayName(), 'long-tooltip': 'true' }) //NO I18N
				let keyboardShortcut = createAndSetAttributes('tooltip-content');//NO I18N
				let shorcutKey = createAndSetAttributes('span', { class: 'zps-tooltip-shortcut' }); //NO I18N
				keyboardShortcut.textContent = moduleObject.getDisplayName()
				if (moduleObject.getkey() && moduleObject.getkey() != '') {
					keyboardShortcut.appendChild(shorcutKey);
				}
				shorcutKey.textContent = moduleObject.getkey()
				textElement.textContent = moduleObject.getDisplayName()
				if(moduleObject.getIcon()){
					menuElement.appendChild(createAndSetAttributes('i', { class: moduleObject.getIcon() })) //NO I18N
				}else{
					menuElement.appendChild(createAndSetAttributes('IMG', { src: moduleObject.getImgUrl() })) //NO I18N
				}
				
				menuElement.appendChild(textElement)
				textElement.appendChild(keyboardShortcut)
			}

			menuElement.setAttribute('global-add-module', moduleName)
 			if(GlobalAdd.Constants.ImportSet.has(moduleName)){
                fragmentImport.appendChild(menuElement)
            }else{              
                fragment.appendChild(menuElement)
            }
		})
		menuList.appendChild(fragment)
		importMenuList.appendChild(fragmentImport)

		const newMenuList = menuList.cloneNode(true);
		menuList.parentNode.replaceChild(newMenuList, menuList);
		const newImportMenuList = importMenuList.cloneNode(true);
		importMenuList.parentNode.replaceChild(newImportMenuList, importMenuList);
		newImportMenuList.addEventListener('click', GlobalAdd.Events.menuClick);
		newMenuList.addEventListener('click', GlobalAdd.Events.menuClick);
		importMenuList.childNodes.length == 0 ? importsplit.classList.add('hide') : '';//NO I18N
	},
	getEnabledModules: function (projectId) {
		return new Promise(function (resolve, reject) {
			GlobalAdd.Data.EnabledModules(projectId)
				.then(function (response) {
					response = response.data
					let moduleSet = new Set()

					const canNewProjectBeCreated = response.ISNEWPROJ
					const tabSet = new Set(Object.keys(response.ENATABOBJ))
					response.ISPUBLICPROJECT ? projectId = '0' : undefined;
					GlobalAdd.Constants.isGAPublicProject = response.ISPUBLICPROJECT;

					// It has to be set first, before the enable checks are done
					GlobalAdd.Modules.TimeOff.peopleUrl = (response.PEOPLEURL) ? response.PEOPLEURL : undefined

					GlobalAdd.Constants.ModuleSet.forEach(function (moduleName) {
						const module = GlobalAdd.Utils.getModule(moduleName)
						if (module && module.enabled(projectId, tabSet) && (!GlobalAdd.Constants.isGAPublicProject || (GlobalAdd.Constants.isGAPublicProject && !GlobalAdd.Constants.ViewerHdnModuleSet.has(moduleName)))) {
							moduleSet.add(moduleName)
						}
					})

					!(Utils.servicedomain == "projects" && Utils.isOwner) ? moduleSet.delete('BasecampImport'): undefined;//NO I18N
					!(Utils.servicedomain == "projects" && Utils.isOwner) ? moduleSet.delete('ImportFromOtherSource'): undefined;//NO I18N
					!permissions.portal_setting.permission.other_import ? moduleSet.delete('JiraImport'): undefined;//NO I18N
					!permissions.bug.permission.import ? moduleSet.delete('IssueImport'): undefined;//NO I18N

					// If the portal has reached the maximum number of projects that can 
					// be created, this wil be false
					if (canNewProjectBeCreated != undefined && !canNewProjectBeCreated) {
						moduleSet.delete(GlobalAdd.Constants._PROJECT)
					}

					if (Utils.isZohoMeetingAvailable && permissions.event.permission.create) {
						moduleSet.add(GlobalAdd.Constants._ZOHOMEETING)
					}

					resolve(moduleSet)
				})
				.catch(function (error) {
					reject(new Set())
					console.error(error)
				})
		})
	}
}

