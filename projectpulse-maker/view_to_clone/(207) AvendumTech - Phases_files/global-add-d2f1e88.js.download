    getDisplayName: function () {
        return Utils.bugReplaceValue
    },
    getIcon: function () {
       return Utils.bugClass; //NO I18N
    },
    getkey: function () {
        return '' //NO I18N
    },
    load: function (data) {
        GlobalAdd.Import.constructImportForms('IssueImport'); //NO I18N
    },
    enabled: function (projectId, tabSet) {
        return (!Utils.isBundledPortal && Utils.bugVisibility && (projectId == '0' || (tabSet.has('Issues') || tabSet.has('Issue'))) && (getPermission(projectId).bug.permission.create === true || projectId == '0') && (Utils.isBugPortal || (!Utils.isBugPortal && permissions.bug.permission.import))) //NO I18N
    },
	getSuccessMessage: function () {
		return getI18nValue('zp.bug.importscheduled'); //NO I18N
    },
    getLink: function (data) {
        return 'buginfo/' + data.projectId + '/' + data.entityId //NO I18N
    },
    formatResponseForCalendar: function (response) {
        let mapping = {"BUGID": "id", "BUG_TITLE": "name", "status_id": "issue_status_id"};//NO I18N
        response = changeFormatOfEventJSON(mapping,response);
        response.edITTYPE = "SINGLE";//NO I18N
        if(response.hasOwnProperty("assigned_to") && response.hasOwnProperty("assigned_to_zuid"))
        {
            response.owner=[{id: response.assigned_to_zuid, name: response.assigned_to}];                
        }
        return response;
    },
    getPermissionName: function () {
        return 'bug' //NO I18N
    },
    onProjectChange: function (projectData, event, data) {      
        GlobalAdd.States.Project.id = projectData.id;
    }
}

GlobalAdd.Modules.Timesheet = {
	getDisplayName: function () {
		return getI18nValue('zp.tab.timelog') //NO I18N
	},
	getIcon: function () {
		return 'zoho-timesheet' //NO I18N	
	},
	getkey: function () {
		return 'C + L' //NO I18N
	},
	load: function (data) {
		LoadGlobalForm.timelogAdd(data);
	},
	enabled: function (projectId, tabSet) {
		let normalChecks = ((projectId == '0' || tabSet.has('Timesheet')) && (getPermission(projectId).timesheet.permission.create === true || projectId == '0') && ((Utils.servicedomain == 'projects' && Utils.orgLicencePlan != 'Free') || (Utils.servicedomain == 'bugs' && Utils.bugPlan != 'Free')))
		let clientChecks = true
		if (Utils.isClient && projectId == '0') {
			clientChecks = getPermission(projectId).timesheet.permission.create
		}
		return Utils.timesheetVisibility && normalChecks && clientChecks
	},
	getSuccessMessage: function (data) {
		let successMessage = data.isDraft ? "zp.timesheet.draft.submit.success" : getI18nValue(getI18nValue('zp.projcal.addsucc').replace("{0}",getI18nValue('zp.module.timelog'))); //NO I18N
		return getI18nValue(successMessage);
	},
	getLink: function (data) {
		return 'zp/projects/' + data.projectId + '/timelog-detail/' + data.entityId + '?type=' + data.logType //NO I18N
	},
	getPermissionName: function () {
		return 'timesheet' //NO I18N
	},
	onProjectChange: function (projectData, event, data) {
		let projectId = projectData.id
		let customdate = document.getElementById('customdate') != null ? (document.getElementById('customdate').value) : ""
		document.getElementById(addTimesheetObj.formData.divId).innerHTML = '';
		addTimesheetObj.renderAddTimeSheetForm({ PROJID: projectId, FORMTYPE: "add", custom_date: customdate, DIVID: addTimesheetObj.formData.divId, from: 'mytimesheet' }); // No I18N
	},
	viewEntity: function (data) {
		zpApp.$router.$service.navigateToDetail('timelogdetail', data.entityId, { type : data.logType }).transitionParams = { from : 'globaladd', project_id : data.projectId  };	//no i18n
	}
}

GlobalAdd.Modules.Forum = {
	getDisplayName: function () {
		return getI18nValue('zp.audit.filter.forum') //NO I18N
	},
	getIcon: function () {
		return 'zoho-forums' //NO I18N	
	},
	getkey: function () {
		return 'C + F' //NO I18N
	},
	load: function (data) {
		LoadGlobalForm.forumAdd(data);
	},
	enabled: function (projectId, tabSet) {
		return !GlobalAdd.CallFrom.Calendar && (projectId == '0' || tabSet.has('Forum') && getPermission(projectId).forum.permission.create === true || projectId == '0')
	},
	getSuccessMessage: function () {
		return getI18nValue(getI18nValue('zp.projcal.addsucc').replace("{0}",getI18nValue('zp.forum.tab'))) //NO I18N
	},
	getLink: function (data) {
		return 'zp/forum-detail/' + data.entityId //NO I18N
	},
	getPermissionName: function () {
		return 'forum' //NO I18N
	},
	viewEntity: function (data) {
		zpApp.$router.$service.navigateToDetail('forumdetail', data.entityId, {}).transitionParams = { project_id : data.projectId, fromPage : 'global_add' }; //no i18n
	},
	onProjectChange: function (projectData, event, data) {
		Promise.all([
			import('/asset/forums/forum-util.js'),	//no i18n
			import('/asset/forums/forum-categories')	//no i18n
		])
		.then((modules) => {
			let [ForumUtils, Category] = [modules[0].ForumUtils, modules[1].Category];
			var projectId = projectData.id

			// Change the project in the form
			document.getElementById('forum-add-form').setAttribute('data-project-id', projectId)

			// Set projectId and render attachment bar
			let attachmentBar = TSG.jQuery.tmpl('attachmentPopup', {//NO I18N
				'comp': 'attachment_bar',//NO I18N
				'popup_location': Attachments.Locations._forumAttachments, //NO I18N
				project_id: projectId
			})

			jQuery('#forumAttachmentContainer').html(attachmentBar)

			if (projectId == '0') {
				zpselectcomponent.init(document.getElementById('forum-category'), data[0], {
					selectOptions: {
						placeholder: getI18nValue('zp.taskdetforum.selectforum'), //NO I18N
						disabled: true,
					},
				})
			} else {
				// Change the categories based on forum
				Category.Utils.getLatestCategory(projectId).then(function (data) {
					zpselectcomponent.init(document.getElementById('forum-category'), data[0], {
						selectOptions: {
							placeholder: getI18nValue('zp.taskdetforum.selectforum'), //NO I18N
						},
						providerWrapper: ProviderRepository.getNamedProviderWrapper("forum_category_filter", //NO I18N
							ForumConstants.Category, {
							projectId: projectId
						}, {
							range: 100
						})
					})
				})
			}

			// Change @mention users in the editor
			if (Utils.editorObj['forum-editor']) {
				getAndSetMentionData('forum-editor', projectId, 'forums', true) //NO I18N
			}

			// Change users in the bottom bar
			ForumUtils.initUsersBar(projectId, 'forum-users', [Utils.zuid + ""]) //NO I18N

			// Focus the title
			UI.Utils.focus('#forum-title') //NO I18N
		});
	}
}

GlobalAdd.Modules.Event = {
	getDisplayName: function () {
		return getI18nValue('zp.notification.event') //NO I18N
	},
	getIcon: function () {
		return 'zoho-events' //NO I18N	
	},
	getkey: function () {
		return 'C + E' //NO I18N
	},
	load: function (data) {
		if (GlobalAdd.CallFrom.Calendar && caldetails.viewtype === "month") {
			if (data.startDateWithTime == null || data.startDateWithTime == undefined) {
				const eventDateObj = ZPDateTime.now();
				data.startDate = eventDateObj.formatted_date
				data.startDateWithTime = eventDateObj.formatted_date_time
			} else {
				data.startDateWithTime = Events.Utils.fixMMMMDateTimeFormatFromCalendar(data.startDateWithTime);
				data.endDateWithTime = Events.Utils.fixMMMMDateTimeFormatFromCalendar(data.endDateWithTime);
				data.startDate = Events.Utils.fixMMMMDateFormatFromCalendar(data.startDate);
				data.endDate = Events.Utils.fixMMMMDateFormatFromCalendar(data.endDate);
			}
		}
		Events.addForm({ projId: data.projectId, divId: data.containerName, frompage: 'addevent', additionalInfo: data }); //No i18n
	},
	enabled: function (projectId, tabSet) {
		return (projectId == '0' || tabSet.has('Calendar') && getPermission(projectId).event.permission.create === true || projectId == '0')
	},
	getSuccessMessage: function () {
		return getI18nValue(getI18nValue('zp.projcal.addsucc').replace("{0}",getI18nValue('zp.meetings.meeting'))) //NO I18N
	},
	getLink: function (data) {
		return 'zp/collaboration/calendar/events/' + data.entityId //NO I18N
	},
	formatResponseForCalendar: function (response) {
		const calJSON = response
		if (response.hasOwnProperty('project_id')) {
			calJSON.allow_edit = getPermission(response.project_id).event.permission.edit
			calJSON.allow_drag = getPermission(response.project_id).event.permission.edit
			calJSON.allow_delete = getPermission(response.project_id).event.permission.delete
			calJSON.abbrivation = 'E' // No i18n
			calJSON.type = 'meeting'
			calJSON.bhex = '#916aa3' // No i18n
			calJSON.bcolor = 'violet' // No i18n
			calJSON.ISRECADJUSTED = false
			calJSON.status = response.is_open ? 'Open' : 'Closed' // No i18n
			calJSON.start_date_long = ZPDateTime.toMillis(response.starts_at)
			calJSON.due_date_long = ZPDateTime.toMillis(response.ends_at)
			calJSON.comp_sd = ZPDateTime.format(response.starts_at, Utils.dateformat)
			calJSON.comp_ed = ZPDateTime.format(response.ends_at, Utils.dateformat)
			calJSON.sd = ZPDateTime.format(response.starts_at, 'dd/MM/yyyy') // No i18n
			calJSON.ed = ZPDateTime.format(response.ends_at, 'dd/MM/yyyy') // No i18n
			calJSON.start_time = ZPDateTime.format(response.starts_at, 'HH:mm') // No i18n
			calJSON.end_time = ZPDateTime.format(response.ends_at, 'HH:mm') // No i18n
			calJSON.title = response.title
			calJSON.project_name = response.project_name != undefined ? response.project_name : GlobalAdd.States.Project.name
			calJSON.project_id = response.project_id
			calJSON.id = response.id
			calJSON.parent_id = ''
			calJSON.CREATED_BY = response.created_by.id
			calJSON.owner = response.attendees
			calJSON.duration = `${Math.floor(parseInt(response.duration.duration_milli) / 1000 / 60 / 60) + 1}`
			// calJSON.durp_disp = response.duration.duration
			// calJSON.dur_mins = `${Math.floor(parseInt(response.duration.duration_milli) / 1000 / 60)}`

		}
		return calJSON
	},
	getPermissionName: function () {
		return 'event' //NO I18N
	},
	viewEntity: function (data) {
		Events.detail({ eventId: `${data.entityId}` })
	},
	onProjectChange: function (projectData, event, data) {
		const project_id = `${projectData.id}`
		jQuery("#projectId").val(project_id)
		if (project_id == '0') {
			dispNone('participantsDiv') //NO I18N
			jQuery('#events-attachment-bar').addClass('hide')
		} else {
			dispBlock('participantsDiv') //NO I18N
			document.getElementById('participants') != null && Events.Utils.loadAttendees(document.getElementById('participants'), `${project_id}`, [{ name: Utils.myDispName, id: Utils.zpuid }]);
			jQuery('#events-attachment-bar').removeClass('hide').html(jQuery.tmpl('attachmentPopup', { 'comp': 'attachment_bar', popup_location: Attachments.Locations._eventAttachments, project_id })) //No i18n
		}
		Events.addFormDetails(project_id)
		UI.Utils.focus('#newmeeting') //NO I18N
	}
}

