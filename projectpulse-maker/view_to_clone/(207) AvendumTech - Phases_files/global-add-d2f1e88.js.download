GlobalAdd.Modules.ZohoMeeting = {
	getDisplayName: function () {
		return getI18nValue('zp.meeting.meeting') //NO I18N
	},
	getIcon: function () {
		return 'zoho-meeting-integ' //NO I18N	
	},
	getkey: function () {
		return '' //NO I18N
	},
	load: function (data) {
		const formData = (data.startDate == undefined) ? { project_id: data.projectId } : { project_id: data.projectId, DATES: { SD: data.startDate, SDWITHTIME: data.startDateWithTime, ED: data.endDate, EDWITHTIME: data.endDateWithTime } }
		meeting.showForm('add', formData, data.containerName) //NO I18N
	},
	enabled: function (projectId, tabSet) {
		return (Utils.isZohoMeetingAvailable && permissions.event.permission.create)
	},
	getSuccessMessage: function () {
		return getI18nValue(getI18nValue('zp.projcal.addsucc').replace("{0}",getI18nValue('zp.meeting.meeting'))) //NO I18N
	},
	getLink: function (data) {
		return 'mymeetings' //NO I18N
	},
	formatResponseForCalendar: function (response) {
		var meetData = {
			allow_delete: true,
			allow_edit: true,
			bcolor: "red",//no I18n
			bhex: "#FFFFFF",//no I18n
			is_recurring: false,
			duration: 1,
			type: "zohomeeting"//no I18n
		};
		meetData.comp_sd = response.start_date;
		meetData.created_by = response.presenter;
		meetData.durp_disp = response.duration * 60000;
		meetData.sd = convertDateFormat(response.start_date, Utils.dateformat, "dd/MM/yyyy");//no I18n
		meetData.ed = convertDateFormat(response.start_date, Utils.dateformat, "dd/MM/yyyy");//no I18n
		meetData.id = response.meeting_id;
		meetData.owner = [];
		var attendees = response.internal_participants;
		for (var i = 0; i < attendees.length; i++) {
			meetData.owner.push({ 'id': attendees[i].id, 'name': attendees[i].name });
		}
		meetData.project_id = response.project_id;
		meetData.project_name = response.project_name;
		meetData.start_time = response.start_time;
		meetData.end_time = response.end_time;
		meetData.status = response.status;
		meetData.title = response.topic;
		meetData.allow_drag = true;
		return meetData;
	},
	getPermissionName: function () {
		return 'event' //NO I18N
	},
	viewEntity: function (data) {
		meeting.showForm('details', { project_id: data.projectId, meeting_id: data.entityId }) //NO I18N
	},
	onProjectChange: function (projectData, event, data) {
		var projectId = projectData.id
		if (projectId == "" || projectId == '-1' || projectId == '0') {
			dispNone('zohomeetingparticipantcontainer') //NO I18N
		} else {
			dispBlock('zohomeetingparticipantcontainer') //NO I18N
			let providerWrapper = ProviderRepository.getProviderWrapper(userList.entitytype.projectfullusers.key, { iszuidprimary: true, isactive: true, isconfirmeduser: true, projectid: projectId });
			zpselectcomponent.init(document.getElementById('meeting_user_list'), undefined, {
				selectOptions: { placeholder: getI18nValue('zp.explogs.seluser') },//No I18n
				providerWrapper: providerWrapper,
				customContent: userCustomContent,
				isParentCustomContent: true,
				isIDSearchAvailable: true
			});
		}
		UI.Utils.focus('#topic') //NO I18N
	}
}

GlobalAdd.Modules.TimeOff = {
	// Set via a call 
	peopleUrl: undefined,
	getDisplayName: function () {
		return getI18nValue('zp.people.timeoff') //NO I18N
	},
	getIcon: function () {
		return 'zoho-user-absent' //NO I18N	
	},
	getkey: function () {
		return + 'C + G' //NO I18N
	},
	load: function (data) {
		let element = document.getElementById(data.containerName)
		let peopleDomain = Integrations.people.domain;
		let headerElement = createAndSetAttributes('div', { class: 'slideFormHeaderBand' }) //NO I18N
		let textElement = createAndSetAttributes('div', { class: 'slideFormName' }) //NO I18N
		textElement.textContent = getI18nValue('zp.timeoff.title') //NO I18N
		let iconElement = createAndSetAttributes('i', { class: 'zoho-close cta fs10px mLauto' }) //NO I18N
		iconElement.addEventListener('click', GlobalAdd.Modules.TimeOff.close)
		headerElement.appendChild(textElement)
		headerElement.appendChild(iconElement)
		let formContainerElement = createAndSetAttributes('div', { class: 'zps-form-container' }) //NO I18N

		//For uncompressed build append origin with css path 
		if (GlobalAdd.Modules.TimeOff.peopleUrl.split("csspath=")[1].startsWith("..")) {
			var uncompressedUrl = GlobalAdd.Modules.TimeOff.peopleUrl.split("../..");
			GlobalAdd.Modules.TimeOff.peopleUrl = uncompressedUrl[0] + window.origin + uncompressedUrl[1];
		}
		let iframeElement = createAndSetAttributes('iframe', { //NO I18N
			class: 'people-integ-iframe',  //NO I18N
			name: 'invIFrame', //NO I18N
			id: 'invIFrame', //NO I18N
			frameborder: '0', //NO I18N
			scrolling: '', //NO I18N
			fpage: 'invDetailPage', //NO I18N
			projId: data.projectId,
			eType: 12,
			src: GlobalAdd.Modules.TimeOff.peopleUrl,
			onload: "changeIframeTheme(id)", //NO I18N
			'target-origin': peopleDomain, //NO I18N
			'integration-iframe': true //NO I18N
		})
		formContainerElement.appendChild(iframeElement)

		element.appendChild(headerElement)
		element.appendChild(formContainerElement)
	},
	enabled: function (projectId, tabSet) {
		return (GlobalAdd.Modules.TimeOff.peopleUrl != undefined)
	},
	getSuccessMessage: function () {
		return getI18nValue('zp.meeting.addsuccess') //NO I18N
	},
	getLink: function (data) {
		return null
	},
	close: function () {
		if (GlobalAdd.CallFrom.Calendar) {
			if (caldetails.viewtype === 'month') {
				loadMonthData(caldetails.selmonth, caldetails.selyear)
			}
		}
		GlobalAdd.Events.close()
	},
	formatResponseForCalendar: function (response) {
		return response
	},
	getPermissionName: function () {
		return 'invoice' //NO I18N
	}
}

