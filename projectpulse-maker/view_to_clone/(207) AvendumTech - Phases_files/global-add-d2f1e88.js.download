GlobalAdd.Modules.Milestone = {
	getDisplayName: function () {
		return getMileRepValue('zp.milestones.milestone', 'single') //NO I18N
	},
	getIcon: function () {
		return Utils.milestoneIconClass
	},
	getkey: function () {
		return 'C + M' //NO I18N
	},
	load: function (data) {
		let fromPage = addMilestoneFormObj.fromPage.GLOBALADD
		if (data.callFromCalendar) {
			fromPage = addMilestoneFormObj.fromPage.MYCALENDAR
		}
		addMilestoneFormObj.renderAddMileForm({ PROJID: data.projectId, FROM: fromPage, DIVID: data.containerName, FORMTYPE: addMilestoneFormObj.formType.top })
		// jsonConstuctPage(Utils.contPath + '/constquickaddmile.do', 'projId=0&modtype=tasks&pagefor=home&'+getZPCSRF(), 'newmilestone', 'html', data.containerName, '', '0') //NO I18N
	},
	enabled: function (projectId, tabSet) {
		return Utils.milestoneVisibility && ((projectId == '0' || tabSet.has('Milestone')) && (getPermission(projectId).milestone.permission.create === true || projectId == '0'))
	},
	getSuccessMessage: function () {
		return getMileRepValue('zp.projcal.addsucc','single') //NO I18N
	},
	getLink: function (data) {
		return 'zp/milestone-detail/' + data.entityId + '?projectId=' + data.projectId //NO I18N
	},
	formatResponseForCalendar: function (response) {
		let mapping = { "MID": "id", "MTITLE": "title", "MORGSTDATE": "comp_sd", "MORGENDATE": "comp_ed", "MILETYPE": "status" };//NO I18N
		response = changeFormatOfEventJSON(mapping, response);
		response.edITTYPE = "SINGLE";//NO I18N
		if (!response.hasOwnProperty("sd")) {
			response.sd = convertDateFormat(response.comp_sd, Utils.dateformat, "dd/MM/yyyy");//no I18n
		}
		if (!response.hasOwnProperty("ed")) {
			response.ed = convertDateFormat(response.comp_ed, Utils.dateformat, "dd/MM/yyyy");//no I18n
		}
		if (response.hasOwnProperty("MZUID") && response.hasOwnProperty("MOWN")) {
			response.owner = [{ id: response.MZUID, name: response.MOWN }];
		}
		return response;
	},
	getPermissionName: function () {
		return 'milestone' //NO I18N 
	},
	viewEntity: function (data) {
		milestoneDetail.openDetailPage(data.projectId, data.entityId)
	},
	onProjectChange: function (projectData, event, data) {
		var projectId = projectData.id
		UI.Utils.focus('#name') //NO I18N
		ajaxRequest({
			url: Utils.contPath + '/constquickaddmile.do', //NO I18N
			type: _POST,
			args: {
				projId: projectId,
				modtype: 'tasks', //NO I18N
				pagefor: 'home', //NO I18N
			},
			restAPI: false
		}).then(function (response) {
			let data = response.data
			globalMileProjChange(data)
		}).catch(function (error) {
			UI.Utils.showError()
			console.error(error)
		})
		findSticky(".slideFormBottombtn") //NO I18N
	},
}

