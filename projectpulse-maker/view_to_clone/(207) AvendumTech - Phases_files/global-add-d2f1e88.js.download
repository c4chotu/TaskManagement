GlobalAdd.Modules.Issues = {
	getDisplayName: function () {
		return Utils.bugReplaceValue
	},
	getIcon: function () {
		return Utils.bugClass
	},
	getkey: function () {
		return 'C + B' //NO I18N
	},
	load: function (data) {
		let fromPage = "web_global_addbug";//no i18n
		let prefilledFormData ={}
		if (data.callFromCalendar) {
			fromPage = "web_calender_addbug";//no i18n
			prefilledFormData.due_date = GlobalAdd.Utils.getEndDateWithTime();
		}
		LoadGlobalForm.issueAdd({fromPage: fromPage, projectId: data.projectId, prefilledFormData},`#${data.containerName}`,{
			methods: {
				onAfterSubmit: function({recently_added_issues, issue_id}){
				},
				onIssueFormCancel: function(){
					GlobalAdd.Events.close();
				}
			}
		});
	},
	enabled: function (projectId, tabSet) {
		return Utils.bugVisibility && ((projectId == '0' || (tabSet.has('Issues')|| tabSet.has('Issue'))) && (getPermission(projectId).bug.permission.create === true || projectId == '0')) //NO I18N
	},
	getSuccessMessage: function () {
		return getBugRepValue('zp.projcal.addsucc','single') //NO I18N
	},
	getLink: function (data) {
		return 'zp/issue-detail/' + data.entityId //NO I18N
	},
	formatResponseForCalendar: function (response) {

		const dueDate = convertDateFormat(formatISODateString(response.due_date, DateTypes.DATE_ONLY), Utils.dateformat, "dd/MM/yyyy");//no i18n
		let calResponse = {
			abbrivation: 'B', bcolor:'blue', bhex:'#9f7d3e',//no i18n
			comp_ed: formatISODateString(response.due_date, DateTypes.DATE_TIME),
			comp_sd: formatISODateString(response.due_date, DateTypes.DATE_TIME),
			duration:"1",//no i18n
			ed: dueDate,
			id:response.id,
			is_bug_tab_enabled:true,
			issue_status_id: response.status.id,
			owner: [{name:response.assignee.name, id: response.assignee.zuid}],
			parent_id:"",//no i18n
			
			project_id: response.project.id,
			project_name: response.project.name,
			sd: dueDate,
			status:"open",//no i18n
			title:response.name,
			edITTYPE: "SINGLE",//NO I18N
			type:'bug',//no i18n
			addmore: response.addmore,
		}
		let index = response.prefix.indexOf("-I") > 0 ? response.prefix.indexOf("-I")+2 : response.prefix.indexOf("-")+1;
		if(index>0){
			calResponse.proj_bug_prefix = {[response.project.id]: response.prefix.slice(0, index)};
			calResponse.bug_key= response.prefix.slice(index)
		}
		return calResponse;
	},
	getPermissionName: function () {
		return 'bug' //NO I18N
	},
	viewEntity: function (data) {
		zpApp.$router.$service.navigateToDetail('issuedetail', data.entityId).transitionParams = { projID: data.projectId, viewFrom: IssueDetailViewFrom.SEARCH, navigationObject: zpApp.$router.$service.getCurrentNavigationState() };//no i18n
	}
}
