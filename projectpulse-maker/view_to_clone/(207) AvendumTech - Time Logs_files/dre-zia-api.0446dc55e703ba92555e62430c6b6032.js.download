var DREZiaBotAPI=function(){function e(e){const t=e+"=",n=document.cookie.split(";");for(let e=0;e<n.length;e++){let r=n[e];for(;" "==r.charAt(0);)r=r.substring(1,r.length);if(0==r.indexOf(t))return r.substring(t.length,r.length)}return null}return this._feedback=(t,n,r,i,a,o)=>{let c={feedbackID:t,feedback:n,selected:r,script:a,meta:o};const d=new URLSearchParams;for(const e in c)if(c[e]){let t=c[e].toString();"meta"===e&&(t=JSON.stringify(c[e])),d.append(e,t)}fetch((i||"/deluge")+"/api/zia/v1/feedback",{method:"POST",body:d.toString(),headers:{"Content-Type":"application/x-www-form-urlencoded","X-ZCSRF-TOKEN":"drepn="+e("drecn")}})},{sendFeedback:_feedback}}();DRE.ZiaBotAPI=DREZiaBotAPI;