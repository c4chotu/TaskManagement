window.showexporthist='{{if VIEWFOR == "task"}} <div class="slideFormHeaderBand">  <span class="slideFormName">${getI18nValue(\'zp.bug.exporthistory\')}</span>   <span id="exporthistclose" data-viewfor="${VIEWFOR}" onclick="closeexportHist();" class="mLauto link text-ellipsis maxw250 inlineBlock" data-tooltip="${getI18nValue(\'zp.bug.backtoexp\')}" ellipsis="true" tabindex="0">${getI18nValue(\'zp.bug.backtoexp\')}</span> </div> {{if (!FORORG && PROJTEXPOBJ) || (FORORG && ORGTEXPOBJ)}} <div class="zps-form-container"> <div class="zps-form-content"> <table border="0" width="100%" cellspacing="0" cellpadding="0" class="zps-GLT"> <thead> <tr> {{if FORORG}}<th>${getI18nValue(\'zp.home.project\')}</th>{{/if}} <th>${getI18nValueWithModule(\'zp.task.exportview\', Utils.taskSingularValue)}</th> <th>${getI18nValue(\'zp.meetnotify.time\')}</th> <th></th> </tr> </thead> <tbody>  {{if PROJTEXPOBJ}}  {{each(i,PROJTOBJ) PROJTEXPOBJ}}  <tr id=\'texp_${PROJTOBJ.EXPID}\'>  <td>{{if PROJTOBJ.EXPSTAT.toLowerCase() === "overdue"}}${getI18nValueWithModule(\'zp.projpage.overduetask\', Utils.taskPluralValue)}{{else PROJTOBJ.EXPSTAT.toLowerCase() === "all"}}All{{else}}${PROJTOBJ.EXPSTAT}{{/if}}</td> <td data-tooltip="${PROJTOBJ.EXPFULLTIME}" ellipsis="true" class="text-ellipsis">${PROJTOBJ.EXPFULLTIME}</td>   <td class="tar"> <div class="flex aic jcfe"> {{if EXTENSION}} <div class="flex aic zps-bdrR mr10 pr10 maxw200 posrel"> <div class="text-ellipsis {{if EXTENSION.display_data}}link{{/if}}" id="extension_history_${i}" data-tooltip="${EXTENSION.app_name}" ellipsis="true">${EXTENSION.app_name}</div> <i class="zoho-info zps-info-icon fs14px mt-1" data-tooltip="${getI18nValueWithParam(\'zp.extensions.exporthistoryinfo\', [EXTENSION.app_name])}"></i> </div> {{/if}} <a target="_blank" href="${PROJTOBJ.FILEURL}" rel="noopener" class="inlineBlock">  <i class="zoho-import fs15px cta" data-tooltip="${getI18nValue(\'zp.chat.download\')}: ${PROJTOBJ.EXPTYPE}"></i> </a> </div> </td>  </tr>  {{/each}} 