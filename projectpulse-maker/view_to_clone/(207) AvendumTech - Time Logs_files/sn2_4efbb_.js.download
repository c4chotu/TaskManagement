y-color" cta="yes" data-tooltip="${getI18nValue(\'zp.project.restore\')}" onclick="trashRestore(this,\'${PROJINDOBJ.id}\');" data-zpqa="project_restore" tabindex="0"></i> {{if FETCHFOR==\'trash\' && isTrashDeletePermissionAvailable}} <i class="zoho-trash text-red" cta="yes" data-tooltip="${getI18nValue(\'zp.general.delete\')}" onclick="deleteProject(\'${PROJINDOBJ.id}\', ${PROJINDOBJ.cells[1].data == \'12\'});" data-zpqa="project_delete" tabindex="0"></i> {{/if}} </div> </td> <td class="zps-cell-td"></td> </tr> {{/each}} </tbody> </table>  <script> function deleteProject(projid, isTemplate) { new DeletePopupDialog({  header: getI18nValue(isTemplate ? \'zp.projtemp.deltemp\' : \'zp.projpage.deleteproj\'),  body: getI18nValue(isTemplate ? "zp.functionjs.deletetemplate" : "zp.functionjs.deleteproject"),  checkboxtext : getI18nValue("zp.delproject.confirmtext"),  onClick: function () {  var url= Utils.contPath+ \'/trashaction.do?actiontbd=delete&projId=\' + projid + \'&\' +getZPCSRF(); jQuery.ajax({dataType: \'json\',url: url.split(\'?\')[0],data: url.split(\'?\')[1],type: \'POST\',success: function(data) { if(data.ISSUCCESS){ refreshProjectsListViewOnRemove(); UI.Utils.showSuccess({message : getI18nValue(\'zp.projcal.deletesucc\').replace("{0}", isTemplate ? getI18nValue(\'zp.projtemp.projtemplate\') : getI18nValue(\'zp.home.project\')) }); } } });  } }) } function trashRestore(obj,projid) {  let ajaxalre=jQuery(obj).attr(\'ajaxsent\');  if(ajaxalre==\'started\') {  return;  }  jQuery(obj).attr(\'ajaxsent\',\'started\');  const args=JSON.stringify([{module:\'projects\',items:[projid]}]);  ajaxRequest({  url: `/bin/restore`,  apiVersion: _V3,  args: args,  type: _POST,  }).then((response)=>{  UI.Utils.showSuccess({message : getI18nValue(\'zp.trash.restorenotify\').replace("{0}", getI18nValue(\'zp.home.project\')) });  refreshProjectsListViewOnRemove();  zpApp.$router.$service.navigateToDetail(\'projdetail\', projid);  }).catch(error=>{  jQuery(obj).attr(\'ajaxsent\', \'\');  zpTrialBanners.trialPopContainer(\'trashRestoreProject\');   }); } function copyToClipboard(element) { let text = element.textContent; navigator.clipboard.writeText(text); UI.Utils.showSuccess({message : "zp.webtobugform.clipboard"}); if(document.body.getAttribute("integ-iframe") === \'true\') { UI.Utils.copytoclipboard(text); } } <\/script>',window.bugreportslhs='<div class="reports-left-panel-section" tour="reports-panel" tour-axis="y"> <div class="reports-left-panel-title">${getI18nValue(\'zp.bugreports.basicrep\')}</div> {{if fields["CUSTOM_STATUSID"]}} <a display="${getI18nValue(\'zp.webtobugform.status\')}" name="reportsTab" data-zpqa="bugreports_status" data-project-id="${PROJID}" action="basicreports" chartType="basic" id="status_${PROJID}" bugProperty="status" ellipsis="true" data-tooltip="${getI18nValue(\'zp.webtobugform.status\')}" class="reports-left-panel-item">${getI18nValue(\'zp.webtobugform.status\')}</a> {{/if}} {{if fields["ASSIGNEE_ZPUID"]}} <a display="${getI18nValue(\'zp.bug.assignee\')}" name="reportsTab" data-zpqa="bugreports_assignee" data-project-id="${PROJID}" action="basicreports" chartType="basic" id="assignee_${PROJID}" bugProperty="assignee" ellipsis="true" data-tooltip="${getI18nValue(\'zp.bug.assignee\')}" class="reports-left-panel-item">${getI18nValue(\'zp.bug.assignee\')}</a> {{/if}} {{if fields["REPORTER"]}} <a display="${getI18nValue(\'zp.bugform.reporter\')}" name="reportsTab" data-zpqa="bugreports_reporter" data-project-id="${PROJID}" action="basicreports" chartType="basic" id="reporter_${PROJID}" bugProperty="reporter" ellipsis="true" data-tooltip="${getI18nValue(\'zp.bugform.reporter\')}" class="reports-left-panel-item">${getI18nValue(\'zp.bugform.reporter\')}</a> {{/if}}  <a display="${getI18nValue(\'zp.bugset.escalation\')}" name="reportsTab" data-zpqa="bugreports_escalation" data-project-id="${PROJID}" action="basicreports" chartType="basic" id="escalation_${PROJID}" bugProperty="escalation" ellipsis="true" data-toolt