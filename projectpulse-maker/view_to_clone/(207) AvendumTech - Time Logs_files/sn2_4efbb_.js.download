h - calc(var(--topHeaderHeight) + var(--wmsbarHeight)));">  <div class="ibvat m0auto tac">  <img src="${getCdnUrl(\'img\',\'images/svg/emptylargeicon/access-denied.svg\')}" class="empty-state-img">  <div class="tac">  <div class="emptyscreen-h1">${getI18nValue("zp.marketplace.extninaccessible")}</div>  {{if permissions.portal_setting.permission.portal_setting}}  <div class=\'emptyscreen-h4\'>${getI18nValue("zp.marketplace.accessdenied1")}</div>  <a href=\'${url}\' class=\'zps-primary-button mT15\'>${getI18nValue("zp.marketplace.modifysetting")}</a>  {{else}}  <div class="emptyscreen-h4">${getI18nValue("zp.marketplace.accessdenied2")}</div>  {{/if}}  </div>  </div>  </div> {{else comp === \'export_connection\'}} <div class="empty-state-container"> <img src="${getCdnUrl(\'img\',\'images/svg/emptylargeicon/empty_state_marketplace_connection_available.svg\')}" class="empty-state-img"> <div class="emptyscreen-h1">${getI18nValue(\'zp.marketplace.renderconnectionhead\')}</div> <div class="emptyscreen-h4 mb20 w100per">${getI18nValue(\'zp.marketplace.renderconnectionmsg\')}</div> <span class="zps-primary-button" data-zpqa=\'export_connection\' id="authorize_app_export_${id}">${getI18nValue(\'zp.marketplace.renderconnectionbtn\')}</span> </div> <div id="authorizeConnectionMsg_${location_name}"></div> {{else comp === \'export_skeleton\'}} <div id="export_extension_location" class="w100per h100per oflowh"></div> <div id="export_configure_location"></div> <span id="export_config${extension.id}" style="display: none;" class="config-setup-icon-R T60" data-tooltip="${getI18nValue(\'zp.marketplace.editconfiguration\')}"><i class="zoho-gear"></i></span> {{else comp === \'export_configuration\'}} <div class="empty-state-container"> <img src="${getCdnUrl(\'img\',\'images/svg/emptylargeicon/empty_state_marketplace_connection_available.svg\')}" class="empty-state-img"> <div class="emptyscreen-h1">${getI18nValue(\'zp.marketplace.renderconfighead\')}</div> <div class="emptyscreen-h4 mb20">