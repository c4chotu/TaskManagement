-comment-placeholder\')].filter(Boolean); editors.forEach(elem => elem.addEventListener(\'mouseup\', handleEditorMouseUp)); }, 1000); <\/script> {{else comp == \'dragdroplayer\'}} <div id="dropboxlayer" class="zps-attachment-drop disabledTemp dropboxlayer">  <div class="attachment-drop-box">  <div class="zoho-drop-file fs27px folderImgHolder mT0"></div>  <div class="mt5 fs14px">${getI18nValue(\'zp.smartadd.dropfiles\')}</div>  </div>  <input type="file" multiple style="opacity: 0;" class="g-droparea pointer border-box posabsonly T0"> </div> {{else comp == \'header_item\'}} <span class="zps-attach-tabitem {{if typeof selected_tab != \'undefined\' && selected_tab}}active{{/if}}" data-tabname="${item_name}" onclick="sE(event);Attachments.UI.changeTab(this, jQuery(this).attr(\'data-tabname\'));" tabindex="0"> <i class="${item_class}"></i> <span data-tooltip="${item_name}" ellipsis="true">${item_name}</span> </span> {{else comp == \'skeleton\'}} <div id="attachment_pop" data-refid="${ref_id}" onmouseup="sE(event);" onclick="sE(event);" class="zps-attachment-cover" data-popup-location="${popup_location}" data-body-overflow="${popup_body_overflow}" data-isdirectuploadlocation="${isdirectuploadlocation}" data-entityid="${popup_entity_id}" project_id="${project_id}"> <div class="zps-attach-container"> <div class="zps-loader hide"></div> <div class="zps-attach-header"> <div id="attachment_header_container" class="zps-attach-tab"></div>  <span class="zps-attach-more" id="attachmentmoretabs" data-connecteddom="true"> <i class="zoho-ellipsis" onclick="removeHide(\'attachmentmoretablist\')"></i> <div class="zps-pop-container T60 L0 hide" pop-arrow="TL" id="attachmentmoretablist"> <div id="attachextnmorelist" class="with-list-icon maxw200"></div> </div> </span>  <i class="zoho-close zp-attach-close icta" data-tooltip="${getI18nValue(\'zp.general.close\')}" onclick="sE(event);Attachments.UI.closePopUp(\'${ref_id}\',\'${popup_location}\');" tabindex="0"></i> </div> {{if typeof(showWDMigrationBanner)!=\'undefined\' && showWDMigrationBanner}} {{if isFreePlan}} <div class="modal-layout"><div class="modal-icon-panel"><img src="${getCdnUrl(\'img\',\'images/wd_migrate_banner.png\')}"></div> <div class="modal-content-panel"> <div class="flex fdcolumn"> <div class="font-bold fs20px mb15">Migrate to Zoho WorkDrive</div> <div class="lh26 fs16px" style="flex-wrap: wrap;">Zoho Projects now provides enhanced document management capabilities for your projects, with all documents and attachments securely stored in <span class="font-bold">Zoho WorkDrive</span>. <div class="mt25"> Attachments can be uploaded only after migrating to <span class="font-bold">Zoho WorkDrive</span>. {{if Utils.profileType==Utils.PROFILE_PORTALOWNER}}Please complete the migration to continue.{{else}}Please contact your administrator to complete the migration.{{/if}} </div> </div> {{if Utils.profileType==Utils.PROFILE_PORTALOWNER}} <button type="button" class="zps-primary-button mt30" zps-loader="" attention="" value="" data-tooltip="Migrate Now" data-zpqa="migrate_now" click="ruc-button =&gt; onClick()" keypress="ruc-button =&gt; onKeypress(event)" style="max-width: max-content;"> <a href="#setup/apps/workdrive" target="_blank">Migrate Now</a></button> {{/if}} </div> </div> </div> {{else}} <div id="wd_migration_banner" class="wd-migration-banner"> <div class="tac lh22"> <span><div style="padding: 0 13px 0 13px;">Migrate your project documents to <span class="font-bold">Zoho WorkDrive</span> before <span class="font-bold">April 30, 2026</span> for folder level permission management and a better experience. {{if Utils.orgLicencePlan=="ZohoOneEnterprise" || Utils.orgLicencePlan=="ZohoOneEnterpriseTrial"}}After this date, we will migrate your project documents and attachments to your Zoho WorkDrive automatically. {{/if}}{{if Utils.profileType==Utils.PROFILE_PORTALOWNER}}<a href="#setup/apps/workdrive" target="_blank" style="color: #f9e400;margin-left:5px;" class="font-semi-bold tuline">Migrate Now</a>{{/if}}{{if Utils.profileType==Utils.PROFILE_ADMIN}} Contact your portal owner for the migration.{{/if}}</div></span> </div> </div> {{/if}} {{/if}} <div id="attachment_main_container" class="zps-attach-area {{if typeof(showWDMigrationBanner)!=\'undefined\' && showWDMigrationBanner && isFreePlan}} hideimp {{/if}}"></div> </div> </div> {{else comp == \'desktop\'}} <div id="desktop_container" class="zps-attach-frame"> <div class="g-droparea drop-container"> <input type="file" multiple title="${getI18nValue(\'zp.screengrab.clickupload\')}" id="popup-attach-center" onchange="Attachments.Utils.showCurrentFileList(event.target.files, \'${popup_location}\');this.value=null;"> <div class="gDropContent"> <div class="table-cell w100per vam"> <div class="onDragImgHolder">  <div class="hand"> <span class="finger thumb"></span> <span class="finger"></span> <span class="finger"></span> <span class="finger"></span> <span class="finger"></span> <span class="palm"></span> <span class="paperForDropFile"></span> </div>  <div class="folderImgHolder">  <img src="${getCdnUrl(\'img\',\'images/folder-ondrag.svg\')}">  </div>   <img src="${getCdnUrl(\'img\',\'images/folder-default.svg\')}" class="frontFolder">  </div> <div class="onDragImgHolder hide"> <div class="fileTransitionBackDrop"> <img src="${getCdnUrl(\'img\',\'images/file3.svg\')}"> </div> <div class="fileTransitionFront"> <img src="${getCdnUrl(\'img\',\'images/file1.svg\')}"> </div> <div class="folderImgHolder"> <div class="fileOnFolder"> <img src="${getCdnUrl(\'img\',\'images/file1.svg\')}"> </div> <img src="${getCdnUrl(\'img\',\'images/folder-ondrag.svg\')}"></div> </div> <div class="contentForText"><span class="attach-detVals">${getI18nValue(\'zp.attachments.drophere1\')}<span class="col777 ml3">{{if navigator.appVersion.indexOf("Mac") != -1}} ${getI18nValue(\'zp.shortcut.cmdv\')} {{else}} ${getI18nValue(\'zp.shortcut.ctrlv\')} {{/if}}</span></span><span class="attach-detVals">${getI18nValue(\'zp.attachments.drop