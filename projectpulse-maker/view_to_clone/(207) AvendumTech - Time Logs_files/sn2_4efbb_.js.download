ta-popup-location="${file.popup_location}"{{/if}} {{if file.notUpload }} not-upload {{/if}} > {{if file.app_type == Constants.cl().WHITEBOARD}}  <div class="attach-details ${file.third_party_file_id}" attach-details="${JSON.stringify(file)}"></div> {{/if}}  <div class="attach-type posrel" style="background-color: ${file.color} !important; border-color: {{if file.is_annotatable}} {{else}}{{if file.app_type != Constants.cl().WHITEBOARD}}${file.color};{{/if}}{{/if}}">  {{if file.is_annotatable}}  {{if file.editMode}}  <img src="${file.file_data}" onclick="sE(event);Attachments.FileActions.annotateInEdit(this);" onerror="imgError(this, \'filelist\', \'${file.file_extn}\')">  {{else}}  <img src="${file.file_data}" onclick="sE(event);Attachments.FileActions.annotate(this);" onerror="imgError(this, \'filelist\', \'${file.file_extn}\')">  {{/if}}  {{else}}  ${file.file_extn_caps}  {{/if}}  {{if file.app_type == Constants.cl().WHITEBOARD}}  <img src="${file.file_data}" onclick="sE(event);sE(event);WBActions.annotateBoard(\'${file.third_party_file_id}\');" onerror="imgError(this, \'filelist\', \'${file.file_extn}\')">  {{/if}}  </div>   <div class="pl10 flex aic minw0">  <div class="fs14px rename posrel flexgrow minw0 {{if file.app_type == \'whiteboard\'}} ${file.third_party_file_id} {{/if}}">  <input type="text" filename="{{if file.app_type == \'whiteboard\'}} ${file.file_name} {{else}} ${file.file_name}.${file.file_extn} {{/if}}" filesizeinbytes="${file.filesizeinbytes}" value="${file.file_name}" class="renamedivfeed" onfocus="this.setSelectionRange(0, this.value.length);" onfocusout="{{if file.app_type == \'whiteboard\'}}var n = jQuery(this).val();jQuery(this).next(\'div\').text(n); {{else}} var n = jQuery(this).val();jQuery(this).next(\'div\').text(n+\'.${file.file_extn}\');Attachments.FileActions.rename(this, \'${file.file_extn}\');{{/if}} if(event.keyCode == 13){jQuery(this).blur();sE(event);return false;};" onkeypress="if(event.keyCode == 13){jQuery(this).blur();sE(event);return false;};" onkeydown="if(event.key == \'/\' || event.key == decodeURI(\'%5C\')){UI.Utils.showError({message : getI18nValue(\'zp.attachment.filevalidation\')});return false;}if(event.keyCode == 13){jQuery(this).blur();sE(event);return false;};" {{if file.app_type}} onchange=" WBOperations.renameWhiteBoard(\'${file.attachment_id}\', this.value, \'${file.third_party_file_id}\', \'${file.project_id}\');" {{/if}}>  <div class="text-ellipsis minw0">{{if file.app_type == \'whiteboard\'}} ${unescape(file.file_name)} {{else}} ${unescape(file.file_name)}.${file.file_extn}{{/if}}</div>  </div>   </div>  <div class="attach-filesize">${file.size}</div>  <div class="mLauto file-upldr-action editoptions ${file.is_uploaded === null ? \'hide-actions\' : \'\'} ${file.is_uploaded === false && !file.third_party_file_id ? \' hide-actions show-delete\' : \'\'}"> {{if file.is_uploaded === false && !file.third_party_file_id}} <div class="loading-bar error">${getI18nValue(\'zp.attach.uploadfailed\')}<span class="zoho-export-failed pl5"></span></span></div> {{else}} <div class="loading-bar ${file.is_uploaded !== null ? \'hideimp\' : \'\'}"><div class="progress-bar" id="progress_${file.id}"></div></div> {{/if}}  {{if file.is_annotatable}}  <span data-tooltip="${getI18nValue(\'zp.workdrive.annotate\')}" aria-label="${getI18nValue(\'zp.workdrive.annotate\')}" {{if file.editMode}} onclick="sE(event);Attachments.FileActions.annotateInEdit(this)" {{else}}onclick="sE(event);Attachments.FileActions.annotate(this)"{{/if}}>  <i class="zoho-annotation"></i>  </span>  {{/if}}  {{if file.is_annotatable_board}}  <span data-tooltip="${getI18nValue(\'zp.general.edit\')}" onclick="sE(event);WBActions.annotateBoard(\'${file.third_party_file_id}\');">  <i class="zoho-annotation"></i>  </span>  {{/if}}  <span data-tooltip="${getI18nValue(\'zp.workdrive.rename\')}" onclick="sE(event);jQuery(this).parent().parent().find(\'input\').focus();">  <i class="zoho-rename"></i>  </span>  <span data-tooltip="${g