lue(\'zp.workdrive.title\')}</h1>  <div class="zp-app-description" data-tooltip="${getI18nValue(\'zp.contentlibrary.workdriveconfigtext_projects\')}" ellipsis="true">${getI18nValue(\'zp.contentlibrary.workdriveconfigtext_projects\')}</div>  </div>  </div>  {{/if}}   <div class="zps-setup-infonote mT0 mb20"><i class="zoho-information"></i>${getI18nValue(\'zp.workdrive.migration.note\')}</div>   <div class="mig-note toaster-biege">   <div class="flex aic mb15">  <div id="migrate_now" class="cradio mr20">   <input type="radio" value="0" name="wdmigrate" id="wd_migrate" class="chdetect2" checked="">   <label for="wd_migrate" class="font-medium" onclick="jQuery(\'.scheduleMig\').addClass(\'hide\');">${getI18nValue(\'zp.workdrive.migration.now\')}</label>   </div>  <div class="cradio">   <input type="radio" value="1" name="wdmigrate" id="wd_schedule" class="chdetect2">   <label for="wd_schedule" class="font-medium" onclick="jQuery(\'.scheduleMig\').removeClass(\'hide\');">${getI18nValue(\'zp.workdrive.migration.later\')}</label>   </div>  </div>  <div class="scheduleMig mb15 pb15 pl22imp hide" style="rgba(var(--zpBlackOpac),.06) solid 1px;">  <div class="zps-form-field half-field mb0imp" ismandatory="false" field_type="date" data-datepicker="true">  <div class="field-label-holder">${getI18nValue(\'zp.workdrive.migration.schedule\')}</div> <div class="date-field w70per"> <input type="text" id="schedule" readonly> <div id="date-picker-migrate" data-zppopupcal="zppopupcal"></div> </div> </div>  </div>    <div class="flex aic mb15">  <div id="migrate_team_folder" class="cradio mr20">   <input type="radio" value="0" name="wdfolder" id="wd_folder" class="chdetect2" checked="">   <label for="wd_folder" class="font-semi-bold">${getI18nValue(\'zp.workdrive.folders\')}</label>   </div>  <div class="cradio">   <input type="radio" value="1" name="wdfolder" id="wd_team_folder" class="chdetect2">   <label for="wd_team_folder" class="font-semi-bold">${getI18nValue(\'zp.contentlibrary.wdfolder\')}</label>   </div>  </div> <div class="fs14px mT10 mb15 lh20 font-medium" id="migrate_heading">${getI18nValue(\'zp.workdrive.migration.fheading\')}</div>  <div class="fs13-5px lh20">  <ul class="ul-li-style pl25" id="folder_instructions">  {{each(instructionIndex, instruction) instructions}}  <li>${instruction}</li>  {{/each}}  </ul>  <ul class="ul-li-style pl25 hide" id="teamfolder_instructions">  {{each(instructionInd, tfinstruction) tfinstructions}}  <li>${tfinstruction}</li>  {{/each}}  </ul>  </div>    </div> {{if is_banner}}  <div class="fs14imp mT30 mb15 lh24">  <div>${getI18nValue(\'zp.workdrive.migration.info\')}</div>  <div class="mT20">  <span class="c-checkbox">  <input type="checkbox" id="wdSetupMigCheck">  <label for="wdSetupMigCheck" class="fs14imp">${getI18nValue(\'zp.workdrive.migration.confirmation\')}</label>   </span>  </div>  </div> {{/if}}  </div>    \x3c!-- Bottom button section --\x3e  <div class="marketplace-footer">  <button class="zps-primary-button" zps-loader="no" ladda-btn wd_setting_btn="wdSetupMigrate" class="zps-primary-button" id="wdSetupMigrate" {{if is_banner}}disabled{{/if}} data-zpqa="wd_setup_migrate">  ${getI18nValue(\'zp.workdrive.migration.setup\')} </button> {{if !is_banner}}  <button class="zps-secondary-button ml10" integ="cancel"  onclick="zpApp.$router.navigateTo(\'setup.apps.zoho\');">  ${getI18nValue(\'zp.general.cancel\')}  </button>  {{/if}}  </div>   </div> {{if is_banner}} <div id="wdMigSetup" class="wdMig-setup hide"> <div id="wdmigsetup-loading" class="loading"></div> </div> {{/if}} </div> <script> let schedule = document.getElementById("schedule"); let blockedDays = (\'${blocked_days}\' !== \'\') ? (\'${blocked_days}\').split(",") : []; let currentDate = moment()._d.customDateFormat(Utils.dateformat.toUpperCase());; let tomorrowDate = moment().add(1,\'days\')._d; if(blockedDays.includes(currentDate)){ document.getElementById(\'migrate_now\').querySelector("input").setAttribute(\'disabled\',\'true\');  document.getElementById(\'wd_schedule\').checked = true; } if(schedule) { let unformattedMaxDate = moment().add(1,\'months\')._d; schedule.onclick = function() { let options = { type : ZCTypes.DATETIME, minDate : tomorrowDate.customDateFormat(Utils.dateformat.toUpperCase()), maxDate : unformattedMaxDate.customDateFormat(Utils.dateformat.toUpperCase()), value : this.value, fieldId : this.id, fieldType : "input",  offset : {top : undefined, left : undefined},  startTrigger : \'date-picker-migrate\',  disabledDates : blockedDays,  todayButton : false }; ZCPopupCalendarComponent(options, function(){}) }; } {{if is_banner}} jQuery(\'#wdSetupMigCheck\').change(function() {  if(this.checked) { jQuery(\'#wdSetupMigrate\').removeAttr(\'disabled\');  } else { jQuery(\'#wdSetupMigrate\').attr(\'disabled\',\'\');  } });  jQuery("#wdSetupMigrate").click(function() { toggleSwitchHide(\'wdMigSetup\',\'chooseapp\'); jQuery(\'#wdmigsetup-loading\').addClass(\'hide\'); jQuery(\'#wdSetupMig1\').removeClass(\'active\'); jQuery(\'#wdSetupMig2\').addClass(\'active\'); }); {{/if}} jQuery(\'input[type=radio][name=wdfolder]\').change(function() {  if (this.value == \'0\') {  jQuery("#folder_instructions").removeClass("hide");  jQuery("#teamfolder_instructions").addClass("hide");  document.getElementById("migrate_heading").innerText=getI18nValue("zp.workdrive.migration.fheading");  }  else if (this.value == \'1\') {  jQuery("#teamfolder_instructions").removeClass("hide");  jQuery("#folder_instructions").addClass("hide");  document.getElementById("migrate_heading").innerText=getI18nValue("zp.workdrive.migration.tfheading");  } }); <\/script> ',window.newUserOnboarding='<div id="onBoardDiv" class="zps-onboard-localbase"> <style> .zps-onboard-localbase ~ .zps-mid-pop{ z-index:10; }  .zps-onboard-localbase {  background-color: rgb(var(--zpFormElement)); background-image: radial-gradient(at 10% 13%, #47eaff 0px, transparent 50%), radial-gradient(at 86% 7%, #66c9ff 0px, transparent 50%), radial-gradient(at 48% 29%, #8afbff 0px, transparent 50%), radial-gradient(at 10% 82%, #94bdff 0px, transparent 50%), radial-gradient(at 85% 83%, #33e7ff 0px, transparent 50%);  position: fixed; z-index: 9; top: 0; right: 0; bottom: 0; left: 0; display: flex; align-items: center; justify-content: center; color: #000;  --zpPrimary: 0, 56, 233 !important; --zpPrimaryHover: 230, 240, 255 !important } .zps-onboard-local{ background-color: rgba(var(--zpFormElement), 0.4); border-radius: 10px; padding:1.73vw; width: 90vw;height: 88vh; position: relative;display: flex;flex-direction: column;align-items: center; } .zps-onboard-local{ --zpFormElement: 255, 255, 255; --zpFormElementBdr: 217, 226, 236; --zpOnData: 32, 33, 35; } .zps-onboard-local > h1{ font-size: 1.55vw; line-height: 2.05vw; margin-bottom: 0.57vw; color: rgb(var(--zpPrimary)); font-family: var(--fontmedium); flex:0 0 auto; display:block; } .zps-onboard-local > h4{flex: 0 0 auto; display: block; color: rgb(var(--zpOnDataLight)); font-size: 1.1vw; font-family: var(--fontmedium); white-space: normal; text-overflow: ellipsis; width: 37vw; text-align: center !important; line-height:1.8vw; } .zps-onboard-navi{ position: absolute; top: 0; bottom: 0; margin: auto; padding-inline: 0.6vw; column-gap: 0.4vw; transition: 0.2s; } .zps-onboard-navi:not([disabled]){ background-color: #f9fdff; color: #3f4042; cursor: pointer; border: 1px solid transparent; } .zps-onboard-navi:not([disabled]):hover{ box-shadow: 0px 0px 10px #47eaff70; border: 1px solid rgb(var(--zpPrimary), 0.5); color: rgb(var(--zpPrimary)); } .zps-onboard-navi[disabled]{ cursor: not-allowed; background-color: rgba(var(--zpDisabled), 0.5); color: rgba(var(--zpOnDisabled), 0.4); border: 1px solid transparent; } body[dir="rtl"] .zps-onboard-navi{transform: scaleX(-1);} body:not([dir="rtl"]) .zps-onboard-navi.onbd-next, body[dir="rtl"] .zps-onboard-navi.onbd-prev{ right: 1.15vw; padding-left: 0.9vw; } body:not([dir="rtl"]) .zps-onboard-navi.onbd-prev, body[dir="rtl"] .zps-onboard-navi.onbd-next{ left: 1.15vw; padding-right: 0.9vw; } .zps-onboard-navi.onbd-go{ right: 1.15vw; background-color:rgb(var(--zpPrimary)) !important; color:rgb(var(--zpOnPrimary)) !important; padding: 0 1.73vw; } body[dir="rtl"] .zps-onboard-navi.onbd-go{ right:unset; left: 1.15vw; } .onboard-slide-content{ width: 100%; height: 100%; overflow:auto; display:flex; align-items: center;justify-content: center; scrollbar-width: none; -ms-overflow-style: none; } .onboard-slide-content::-webkit-scrollbar { display: none; scrollbar-width: none; } .onboard-slide-wrap{ padding-top: 1.73vw; display: flex; height: 100%; flex-direction: column; } .zps-onboard-navi .zpToolTip{opacity:0;} .zps-onboard-navi:hover .zpToolTip{opacity:1;} .onboard-slide-content[type="image-link"]{ align-items:flex-end; } .zps-onboard-graphic{ height:72vh; max-width: 95%; overflow:hidden; position:relative; } .zps-onboard-graphic > iframe, .zps-onboard-graphic > video{ height:100%; border:0; outline:none; } .zps-onboard-graphic > img{ object-fit:contain; height:100%; max-width: 100%; } .zps-onboard-graphic .img-map{ position: absolute; width: 13%; height: 5%; right: 2%; bottom: 4%; display:inline-flex; } .zps-onboard-graphic .img-map > .img-map-area{ display:inline-block; width:50%; height:100%; cursor:pointer; flex:0 0 auto; } .onboard-timeline{ width:400px; height:20px; display:flex; flex-direction:row; align-items:center; justify-content:center; position:relative; margin-top:30px; } .onboard-timeline > span{ width:9px; height:9px; border-radius:50%; flex:0 0 auto; display:inline-flex; align-items:center; justify-content:center; position:relative; background-color:rgb(var(--zpPrimary));} .onboard-timeline > span.active ~ span{ background-color:rgba(0,0,0,.12); } body:not([dir="rtl"]) .onboard-timeline > span:not(:first-child){ margin-left:25px; } body[dir="rtl"] .onboard-timeline > span:not(:first-child){ margin-right:25px; } .onboard-timeline > span:not(:first-child):before{ content:\'\'; background-color:inherit; position:absolute; height:1px; width:25px; left:-25px; } body[dir="rtl"] .onboard-timeline > span:not(:first-child):before{ left:unset; right:-25px; } .zps-onboard-slide { width: calc(100% - 5vw); min-height: 0; height: 100%; flex: 1; } .edit-profile-picture { width: 7vw; height: 7vw; border-radius: 50%; margin: 0 auto; } .edit-profile-picture > img { width: 100%; height: 100%; } .zps-mid-pop{ --zpPrimary: 0, 56, 233 !important; --zpPrimaryHover: 230, 240, 255 !important; } .zp_productlogocont { text-align: center !important; display: inline-flex; width: 100%; justify-content: center; margin: 1.2vw 0; } .zp_productlogoimg{ height: 3.7vw; overflow: hidden;} .welcome-sub-text{color: #000; padding-top: 0.8vw; font-size: 1.28vw; margin-bottom: 0.9vw;} .watch-webinar{ position: absolute; bottom: 42px; justify-content: space-between; padding-right: 1.15vw; } .zps-skip-option{ background: #f9fdff; color: rgb(var(--zpPrimary)); column-gap: 0.2vw; cursor: pointer; padding: 0px 1.8vw; } .zps-onboard-navi, .zps-skip-option{ height: 2.2vw; font-size: 0.9vw; display: inline-flex; align-items: center; justify-content: center; border-radius: 6px; } .onboard-profile-hold {  width: 21.3vw;  height:auto; } .onboard-profile-hold.profile-pic-only {  width: 28.85vw;  margin: 0 auto;  display: flex;  align-items: center;  justify-content: center;  flex-direction: column; } .onboard-profile-title {  font-size: 1.15vw;  font-family: var(--fontsemibold); color: rgb(var(--zp777));  margin: 1.73vw 0;  text-align: center; } .onbform-fld-required {  display: block;  position: relative;  width: 100%;  height: 4.051vw;  padding-top: 0.57vw;  margin-bottom: 0.57vw;  transition: 0.25s ease-in-out all; } .onbform-fld-required input[type=text] {  display: block;  width: 100%;  height: 2.431vw;  font-size: 0.99vw;  padding: 0;  border: none;  border-radius: unset;  color: rgb(var(--zpOnData));  border-bottom: 1px solid rgba(var(--zpPrimary), 0.6) !important;  background: transparent;  transition: 0.25s ease-in-out all;  border-bottom: 1px solid rgb(var(--zpPrimary)); } .onbform-fld-required label {  position: absolute !important;  top: 1.05vw;  font-size: 0.86vw;  line-height: 1.28vw;  color: #4d5055;  pointer-events: none;  transition: 0.25s ease-in-out all; left: 0; } .onbform-fld-required input[type=text]:focus ~ label, .onbform-fld-required input[type=text]:valid ~ label {  top: -0.45vw;  font-size: 0.85vw; } .onboard-gsct-portal-container .zps-primary-button,  .onboard-gsct-portal-container .zps-secondary-button {  height: 1.84vw !important;  font-size: 0.96vw !important;  padding: 0 1.15vw !important;  min-width: 5.19vw !important; } .onboard-gsct-portal-container .zps-primary-button.loadingbutton,  .onboard-gsct-portal-container .zps-primary-button[zps-loader=yes],  .onboard-gsct-portal-container .zps-secondary-button.loadingbutton,  .onboard-gsct-portal-container .zps-secondary-button[zps-loader=yes] {  font-size: 0 !important; } .onboard-gsct-portal-container .zps-primary-button[disabled] {  background-color: rgba(var(--zpPrimary), 0.4);  border: 1px solid rgba(var(--zpPrimary), 0.2);  cursor: not-allowed; } </style> <div class="zps-onboard-local onboard-gsct-portal-container" count="${count}" length="${length}"> {{if isFirstData}} <div class="zp_productlogocont"> <img src="{{if Utils.isBugPortal}}${getCdnUrl(\'images\',\'images/bugs-logo-lockup.png\')}{{else}}${getCdnUrl(\'images\',\'images/projects-logo-lockup.png\')}{{/if}}" class="zp_productlogoimg reh"> </div> <div class="welcome-sub-text">${getI18nValue(\'zp.general.hello\')} <span>${Utils.myFistName},</span></div> {{/if}} <h1 >${header}</h1> {{if !isFirstData}}<h4 >${content}</h4>{{/if}} {{if video}}{{/if}}  <span id="onBoardingPrevBtn" class="zps-onboard-navi onbd-prev" {{if count == 0}} disabled {{/if}} {{if count != 0}} onclick="onboardingTourNavigateBtn(${count},this.id);"{{/if}}> <i class="zoho-left-arrow-plain"></i> <span>${getI18nValue(\'zp.onboardingtour.prev\')}</s