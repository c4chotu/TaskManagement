ath}}  <span class="folderpicker" id="picker_${folderi}" value="${folder.id}">${folder.name}</span>   {{if folderi != folderPath.length - 1}}  <span class="zoho-right-arrow-plain fs10px col999 mr2 posrel T1 ml2"></span>  {{/if}}  {{/each}}  </div>  </div> {{if (team_folders && team_folders.length != 0) || (folders && folders.length != 0) || (personal_folders && personal_folders.length !=0)}} <div class="posrel">  <div class="zps-pop-container minw200 maxw500 p0imp inlineProjcolumnDiv hide Bminus30 B-35 R15 tal" word-wrap="true" id="wdpop" oscclass="hide">  <div class="pop-arw {{if isRTL}}arwLeft{{else}}arwRight{{/if}} B30 z-1"></div>  <div class="p8 fs14px zps-dropdown-search posrel w100per">  <div class="zps-dropdown-searchbox pl0imp">  <i class="zoho-search"></i>  <input onkeyup="contentLibrary.addProjectDocs.searchFolder(this)" id="wdFolderSearch"  data-zpqa="wd_folder_search_input" type="text"  placeholder="Search">  </div>  <div class="maxh200 widget-custom-scroll overflowAuto">  <span id="wdDefaultFolder" >  <div id="wdpoplistPersonal">  <div class="taskDescRow pointer editedData" onclick="contentLibrary.addProjectDocs.selectDefaultFolder(event)">  <div class="popuplist fleximp aic" title="${getI18nValue(\'zp.contentlibrary.defaultfolder\')}" tabindex="0">  <i class="ml0 pr5 zoho-info zps-info-icon" tabindex="0"id="defaultTooltip"></i> <span id="defaultFolderName" data-zpqa="default_folder">${getI18nValue(\'zp.contentlibrary.defaultfolder\')}</span>  </div>  </div>  </div>  </span>    <span id="searchPopulationPersonal"></span>  {{if folders.length}}  <div class="p5 pl5 taskDescRow pointer editedData">  <div class="text-ellipsis w100per font-medium" title="WorkDrive Folder">  ${getI18nValue(\'zp.docs.folder\')}  </div>  </div>  {{/if}}  <span id="wdpopstruct">  <span id="wdpoplistTeam">  {{each(folderi, folder) folders}}  <div class="pl5 taskDescRow pointer editedData" id="folder_${folder.workdrive_folder_id}"  data-zpqa="wd_folder_selection_${folder.workdrive