m external websites using the Web to issue form.</div> {{if SHOWSTOREURL=="true"}} <div class="fp-btn-group"> {{if isProjTrialAvailable || hasExtendTrialAvail}} <div class="zps-upgextend-trialbut trialBut" onclick="zpTrialBanners.enableTrial(\'${trialType}\', \'IssueTrackerSettings\')" tabindex="0">${message}</div> {{/if}} <div class="zps-upgextend-trialbut upgradeBut" onclick="${trackingFunc};addToMicsForUpgrade(\'Store_Upgrade\', \'lhs_banner\');window.open(\'${Utils.storeURL}\',\'_blank\')" tabindex="0">${getI18nValue(\'zp.general.upgrade\')}</div> \x3c!-- <a class="fp-btn-upgrade giftbox" onclick="addToMicsForUpgrade(\'Store_Upgrade\', \'issuetracker_settings\');window.open(\'${STOREURL}\',\'_blank\')" rel="noreferrer noopener"><img src="${getCdnUrl(\'img\',\'images/png/promo-giftmini.png\')}">${getI18nValue(\'zp.tpmenu.upgradenow\')}</a>--\x3e </div> {{/if}} </div>',window.statusinsertcomment='<form id="comment_stat_${viewkey}_${fdk}" name="comment_stat_${viewkey}_${fdk}" class="attachment-dragdrop-container fl w100per" enctype="multipart/form-data" method="post"> <div class="f_task_cmtbox" style="width:99.5%;float:left;"> <div style="width:100%;background-color: #fff;"> <input type="hidden" id="hashDiv_${fdk}" value="hashfeedcomment_${viewkey}_${fdk}"/> <input type="hidden" id="projectId_${fdk}" value="${viewkey}"/> <input type="hidden" name="projId" id="projId_${fdk}" value="${viewkey}"/> <input type="hidden" name="statusId" id="statusId_${fdk}" value="${fdk}"/> <input type="hidden" name="frompage" id="fromPage_${fdk}" value="taskdetails"/> <input type="hidden" name="${getZPCSRF().split(\'=\')[0]}" value="${getZPCSRF().split(\'=\')[1]}"> <div class="toadd"> <div class="w100per" id="${frompage}comment_${viewkey}_${fdk}" style="{{if frompage == \'ntfn\'}}width: 100%;max-height:80px; {{/if}}outline:none;border:none;-webkit-box-shadow: none; {{if frompage == \'pop\'}} max-width:300px; {{else frompage == \'ntfn\'}} max-width:100%;{{/if}}"></div> \x3c!-- <textarea cols="50" class="w98perimp h80 hide" id="${frompage}comment_${viewkey}_${fdk}" name="mycomment" style="{{if frompage == \'ntfn\'}}width: 100%;max-height:80px; {{/if}}outline:none;border:none;-webkit-box-shadow: none; margin-left:8px; min-height:40px; {{if frompage == \'pop\'}} max-width:300px; {{else frompage == \'ntfn\'}} max-width:100%;{{/if}}"></textarea> --\x3e {{tmpl({\'comp\' : \'file_list_skeliton\'}) "attachmentFileList"}} <table border="0" cellpadding="0" cellspacing="0" width="100%"> <tr><td width="w100per" valign="top"> <div class="w100per" style="position:relative;"> <div id="hash_${frompage}comment_${viewkey}_${fdk}" style="display:none;position:absolute;z-index:100;width:100%"></div> </div> </td> </tr> </table> </div> <div class="f_task_cmtbtmbg"> {{tmpl({\'comp\' : \'attach_file_button\', popup_location: Attachments.Locations._statusCommentAttachments, project_id: projId, editor_id: "comment_stat_"+viewkey+"_"+fdk}) "attachmentPopup"}} <div class="mt8 mb8 fr"> <div id="${frompage}cmtBtn_${viewkey}_${fdk}" class="fr" style="display: block;"> <input id="addStatusComment_${frompage}_${viewkey}_${fdk}" type="button" class="zps-primary-button " value="${getI18nValue(\'zp.general.submit\')}" onclick="addStatusCmt(\'${viewkey}\',\'${fdk}\',\'${frompage}comment_${viewkey}_${fdk}\',this.form, undefined, \'${frompage}\');return false;"> <input id="cancelAddComment_${frompage}_${viewkey}_${fdk}" type="button" class="zps-secondary-button cancelme" onclick="javascript:showHide(\'${frompage}shareurcmt_${viewkey}_${fdk}\',\'${frompage}insertcmt_${viewkey}_${fdk}\');" value="${getI18nValue(\'zp.general.cancel\')}"> <span style="top: 5px; left: -5px; position: relative; display:none;" class="fl" id="loadSt_${fdk}" ></span> </div> </div> </div> </div> </div> </form> <script> blob=[]; addMiniEditor(\'updateCmt_${fdk}\',\'${frompage}comment_${viewkey}_${fdk}\',\'${viewkey}\',\'${fdk}\',\'${frompage}addcom_${viewkey}_${fdk}\',\'false\',\'${frompage}\',\'status_${viewkey}_${fdk}\'); jQuery("textarea[id=\'${frompage}comment_${viewkey}_${fdk}\']").focus(); feedcmtFile = 1; if(jQuery.browser.chrome == true || jQuery.browser.mozilla == true) {  jQuery(\'div[id="grabberforfeedcomment_${fdk}"]\').show();  } else { jQuery(\'div[id="grabberforfeedcomment_${fdk}"]\').hide(); } <\/script> ',window.helppage='<div id="zphelppage" class="zps-learning-center help-videos-center" learning="videos"> <div class="zps-learncenter-header"> <span class="closelc"> <i class="zoho-close" data-tooltip="Close" onclick="closeZPHelpPage();" zps_close></i> </span> </div> <div class="leftAbstab-parent"> <div class="leftAbstab active" data-tooltip="${getI18nValue(\'zp.signout.helpgifs\')}" data-tooltip-pos="bottom-left" ellipsis="true" onmouseover="helpPageUtils.tabHover(this);"><img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/pt-help-videos.svg\')}">${getI18nValue(\'zp.signout.helpgifs\')}</div> <div class="leftAbstab quicky-help" data-tooltip="${getI18nValue(\'zp.signout.quicktips\')}" data-tooltip-pos="bottom-left" ellipsis="true" onmouseover="helpPageUtils.tabHover(this);"><img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/pt-quicktips.svg\')}">${getI18nValue(\'zp.signout.quicktips\')}</div> </div> <div class="zps-pop-searchbar hide" stick-top="yes"> <i class="zoho-search"></i> <input type="text" name="" placeholder="Search Topics"> </div> <div id="zpsLearningList" class="zpslc-widget-container"> <div class="zpslc-help-videos-hdr"> <div class="zplc-title"> <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/pt-help-videos.svg\')}"> <h1>Help Videos</h1> </div> <i class="zoho-close icta mLauto fs11px" data-tooltip="Close" onclick="closeZPHelpPop();" zps_close></i> </div> <div class="zpslc-widget" name="gif_projtemp" video-src="https://workdrive.zohoexternal.in/embed/zxv1y67704125f250407b9b47a0fc6412cc5e"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_projtemp\');" > <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/12_project_template.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="How to create a project template!">How to create a project template!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Simplify the project creation process with project templates in Zoho Projects. Create project templates for each unique industry. Use them to create, customize, and replicate projects across industries to reduce effort and ensure consistency.">Simplify the project creation process with project templates in Zoho Projects. Create project templates for each unique industry. Use them to create, customize, and replicate projects across industries to reduce effort and ensure consistency.</div> </div> <div class="zpslc-widget" name="gif_budgetconcept" video-src="https://workdrive.zohoexternal.in/embed/zxv1y4abd095723214acc870c978e2803d97d"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_budgetconcept\');" > <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/11_budget_concept.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="Getting started with budgets in Zoho Projects!">Getting started with budgets in Zoho Projects!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Here is a quick overview of budget in Zoho Projects. This video helps users understand the key budget terms used in the product.">Here is a quick overview of budget in Zoho Projects. This video helps users understand the key budget terms used in the product.</div> </div> <div class="zpslc-widget" name="gif_tsapproval" video-src="https://workdrive.zohoexternal.in/embed/fs9zu6affe3b046fd440080e8cb87bac3d2c2?"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_tsapproval\');" > <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/10_timsheets_approval.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="How to create and manage Timesheets!">How to create and manage Timesheets!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Enable approvals based on time log or timesheets in Zoho Projects for an enhanced project management process. Manage time specific data to run payroll, client billing, performance reviews, and more with Time log and timesheet approval rules.">Enable approvals based on time log or timesheets in Zoho Projects for an enhanced project management process. Manage time specific data to run payroll, client billing, performance reviews, and more with Time log and timesheet approval rules.</div> </div> <div class="zpslc-widget" name="gif_taskrollup" video-src="https://workdrive.zohoexternal.com/embed/qvruz490c025d3e1e4a3da4111381d395f220"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_taskrollup\');" > <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/09_rollup_video-cover.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="How to enable and disable Task Roll-Up!">How to enable and disable Task Roll-Up!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Compile project data, including the total project duration, anticipated work hours, actual log hours, and percentage completion, using the roll-up feature.">Compile project data, including the total project duration, anticipated work hours, actual log hours, and percentage completion, using the roll-up feature.</div> </div> <div class="zpslc-widget" name="gif_customtabs" video-src="https://workdrive.zohoexternal.com/zvideo/1037394775?autoplay=true&muted=false&"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_customtabs\');" > <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/02b_customizetabs.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="How to Customize Tabs in Zoho Projects!">How to Customize Tabs in Zoho Projects!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Learn how to customize tabs in Zoho Projects. Enable or disable tabs based on business or work preference.">Learn how to customize tabs in Zoho Projects. Enable or disable tabs based on business or work preference.</div> </div> <div class="zpslc-widget" name="gif_leverageai" video-src="https://workdrive.zohoexternal.com/zvideo/1023905900?autoplay=true&muted=false&"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_leverageai\');" > <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/ai-in-zoho-projects.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="How to leverage AI in Zoho Projects!">How to leverage AI in Zoho Projects!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Leverage the power of AI in Zoho Projects. Learn how AI can help you manage your projects and improve productivity.">Leverage the power of AI in Zoho Projects. Learn how AI can help you manage your projects and improve productivity.</div> </div> <div class="zpslc-widget" name="gif_rollup" video-src="https://workdrive.zohoexternal.com/zvideo/1012372547?autoplay=true&muted=false&"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_rollup\');" > <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/05a_project-public-private.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="How to convert a project to Public/ Private Project!">How to convert a project to Public/ Private Project!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="This video shows how you can set your project as private or public without affecting the project management process. Learn to control who can view or modify your project.">This video shows how you can set your project as private or public without affecting the project management process. Learn to control who can view or modify your project.</div> </div> <div class="zpslc-widget" name="gif_cpath" video-src="https://workdrive.zohoexternal.com/zvideo/1012372611?autoplay=true&muted=false&"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_cpath\');"> <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/06a_task-gantt-view.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="How to use Task Gantt View for Project Management!">How to use Task Gantt View for Project Management!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="View, customise, edit, filter, monitor, and compare your project timeline using the Task Gantt view in Zoho Projects.">View, customise, edit, filter, monitor, and compare your project timeline using the Task Gantt view in Zoho Projects.</div> </div> <div class="zpslc-widget" name="gif_baseline" video-src="https://workdrive.zohoexternal.com/zvideo/1012372427?autoplay=true&muted=false&"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_baseline\');" > <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/04a_project-list-gantt-view.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="How to enable List/ Gantt view of Projects!">How to enable List/ Gantt view of Projects!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="This video explores the unique view options available and guides you in selecting the one that best suits your project management process.">This video explores the unique view options available and guides you in selecting the one that best suits your project management process.</div> </div> <div class="zpslc-widget" name="gif_blueprint" video-src="https://workdrive.zohoexternal.com/zvideo/1012372393?autoplay=true&muted=false&"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_blueprint\');" > <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/03a_edit-delete-project.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="How to Edit/ Delete Projects!">How to Edit/ Delete Projects!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Modify project details as per your need and client requirements. This video shows how you can edit project dates, status, users, and more, easily on Zoho Projects.">Modify project details as per your need and client requirements. This video shows how you can edit project dates, status, users, and more, easily on Zoho Projects.</div> </div> <div class="zpslc-widget" name="gif_budget" video-src="https://workdrive.zohoexternal.com/zvideo/1012372238?autoplay=true&muted=false&"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_budget\');" > <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/02a_create-project-template.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="How to create a project from Template Gallery!">How to create a project from Template Gallery!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Learn how to simplify project management with ready-made Project Templates. This video shows how to use predefined, industry-specific templates for quick and hassle-free project creation.">Learn how to simplify project management with ready-made Project Templates. This video shows how to use predefined, industry-specific templates for quick and hassle-free project creation.</div> </div> <div class="zpslc-widget" name="gif_keyboardshort" video-src="https://workdrive.zohoexternal.com/zvideo/1012372340?autoplay=true&muted=false&"> <div class="lcimg-widg" onclick="helpPageUtils.lcPlayVideo(\'gif_keyboardshort\');" > <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/01a_create-project.png\')}"> <span class="playbg"></span> <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="How to create a Project!">How to create a Project!</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Learn how to quickly create projects from scratch using Zoho Projects, saving time and effort as a project manager.">Learn how to quickly create projects from scratch using Zoho Projects, saving time and effort as a project manager.</div> </div> </div>  <div id="zpsQuickVideos" class="zpslc-widget-container"> <div class="zpslc-help-videos-hdr"> <div class="zplc-title"> <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/help-vid/pt-quicktips.svg\')}"> <h1>Quick Tips</h1> </div> <i class="zoho-close icta mLauto fs11px" data-tooltip="Close" onclick="closeZPHelpPop();" zps_close></i> </div> <div class="zpslc-widget" name="quicky_managetimers" video-src="https://workdrive.zohoexternal.in/embed/ma9uqde7cccba03c941789501d4632ae2aa9d"> <div class="lcimg-widg" onclick="helpPageUtils.quickTips(\'quicky_managetimers\');"> <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/quick-tips/quick-manage-timers.png\')}"> <span class="playbg"></span>  <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="Manage Timers from the List View">Manage Timers from the List View</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Quickly add time logs from the list view using timers." aria-label="Quickly add time logs from the list view using timers.">Quickly add time logs from the list view using timers.</div> </div> <div class="zpslc-widget" name="quicky_projbudget" video-src="https://workdrive.zohoexternal.com/zvideo/1035204178?autoplay=true&muted=false&"> <div class="lcimg-widg" onclick="helpPageUtils.quickTips(\'quicky_projbudget\');"> <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/quick-tips/quick-proj-budget.png\')}"> <span class="playbg"></span>  <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="Set Project Budget">Set Project Budget</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Setting up a project budget allows users to track and manage costs. Zoho Projects allows users to quickly set up their budget for both new and existing projects." aria-label="Setting up a project budget allows users to track and manage costs. Zoho Projects allows users to quickly set up their budget for both new and existing projects.">Setting up a project budget allows users to track and manage costs. Zoho Projects allows users to quickly set up their budget for both new and existing projects.</div> </div> <div class="zpslc-widget" name="quicky_gantt" video-src="https://workdrive.zohoexternal.com/zvideo/1035204093?autoplay=true&muted=false&"> <div class="lcimg-widg" onclick="helpPageUtils.quickTips(\'quicky_gantt\');"> <img src="${getCdnUrl(\'img\',\'images/svg/LCsupport/quick-tips/quick-gantt.png\')}"> <span class="playbg"></span>  <div class="lcvideo"></div> </div> <h2 vertical-ellipsis="true" data-tooltip="Add and Manage Task Dependency on the Gantt Chart">Add and Manage Task Dependency on the Gantt Chart</h2> <div class="lcwidg-descr" vertical-ellipsis="true" data-tooltip="Task dependencies can be created and modified from the Gantt Chart in Zoho Projects. Users can use the drag and drop function to quickly associate tasks with each other." aria-label="Task dependencies can be created and modified from the Gantt Chart in Zoho Projects. Users can use the drag and drop function to quickly associate tasks with each other.">Task dependencies can be created and modified from the Gantt Chart in Zoho Projects. Users can use the drag and drop function to quickly associate tasks with each other.</div> </div> <div class="zpslc-widget" name="quicky_customview" video-src="https://workdrive.zohoexternal.com/zvideo/1035204121?autoplay=true&muted=false&"> <d