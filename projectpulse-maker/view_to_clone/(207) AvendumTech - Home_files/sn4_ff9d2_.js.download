const FilterProviders={bugTracker:{name:"bugTracker",keyName:"bugtracker"},bugStatusWorkflow:{name:"bugStatusWorkflow",keyName:"bug_status_workflow"},projects:{name:"projects",keyName:projectsProviderConstants.PROJECTS},projectLayoutList:{name:"projectLayoutList",keyName:projectsProviderConstants.PROJECT_LAYOUTS},projectCustomFields:{name:"projectCustomFields",keyName:projectsProviderConstants.PCFS},projectCustomFieldPickList:{name:"projectCustomFieldPickList",keyName:projectsProviderConstants.PCF_PICKLISTS},projectCustomStatus:{name:"projectCustomStatus",keyName:projectsProviderConstants.PROJECT_CUSTOMSTATUS},projectGroup:{name:"projectGroup",keyName:projectsProviderConstants.PROJECT_GROUP},clientCompany:{name:"clientCompany",keyName:projectsProviderConstants.CLIENT_COMPANY},currencies:{name:"currencies",keyName:projectsProviderConstants.CURRENCIES},mentions:{name:"mentions",keyName:projectsProviderConstants.ATMENTION},taskTimesheetList:{name:"taskTimesheetList",keyName:timesheetproviderContants.TASKTIMESHEETLIST},bugTimesheetList:{name:"bugTimesheetList",keyName:timesheetproviderContants.BUGSTIMESHEETLIST},users:{name:"users",valueFunction:getUserFilterValues},teams:{name:"teams",keyName:userList.entitytype.teams.key},roles:{name:"roles",keyName:userList.entitytype.roles.key},tags:{name:"tags",keyName:tagsProvider.TAGS}};function commonFilterValueProvider(filterData,moduleCallback){const{project_id:project_id,search_term:search_term,index:index,range:range,provider_name:provider_name}=filterData;if(FilterProviders.hasOwnProperty(provider_name)){if(FilterProviders[provider_name].keyName){let optgroups=[],options=[];return new Promise((function(resolve,reject){ProviderRepository.getProviderWrapper(FilterProviders[provider_name].keyName,EMPTY_CRITERIA_OBJECT,{range:range}).callProvider({index:index,searchTerm:search_term}).then((providerResults=>{providerResults.forEach((currentResult=>{options.push({value:currentResult.id,name:currentResult.name})})),optgroups.push({options:options}),resolve(optgroups)}))}))}return FilterProviders[provider_name].valueFunction(filterData)}return new Promise((function(resolve,reject){resolve(moduleCallback(filterData))}))}function getUserFilterValues({project_id:project_id,search_term:search_term,index:index,range:range}){let optgroups=[],providerKey="0"==project_id?userList.entitytype.portalfullusers.key:userList.entitytype.projectfullusers.key,providerWrapper=ProviderRepository.getProviderWrapper(providerKey,{isactive:!0,projectid:project_id,iszuidprimary:!0},{isGroup:!0});return new Promise((function(resolve,reject){providerWrapper.callProvider({index:index,searchTerm:search_term,range:range}).then((userGroups=>{userGroups.forEach((userGroup=>{let options=[];userGroup.options.forEach((user=>{user&&options.push({value:user.id,name:user.name})})),optgroups.push({value:userGroup.id,name:userGroup.name,options:options})})),resolve(optgroups)}))}))}Object.freeze(FilterProviders);